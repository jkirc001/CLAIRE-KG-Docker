"""
LLM Orchestrator - Core of the LLM-first pipeline.

This orchestrator coordinates the complete flow:
Question -> Cypher Generation -> Database Query -> LLM Enhancement -> Answer
"""

import os
import time
from typing import Dict, Any, List, Optional
from dataclasses import dataclass
from rich.console import Console
from rich.syntax import Syntax

from .database import Neo4jConnection
from .langchain_cypher_generator import LangChainCypherGenerator
from .query_validator import QueryValidator, ValidationResult


class DebugFormatter:
    """Structured debug output formatter using Rich console."""

    def __init__(self, debug: bool = False, debug_file: str = None):
        """Initialize debug formatter.

        Args:
            debug: Enable debug output (if False, all methods are no-ops)
            debug_file: Optional path to file to save debug output
        """
        import sys

        self.debug = debug
        self.debug_file = debug_file
        self.console = Console() if debug else None
        self.file_handle = None
        self.phase_num = 0

        # Skip file writing if stdout is piped (e.g., when using tee)
        # tee will capture everything, so we don't need to write to file separately
        stdout_is_piped = not sys.stdout.isatty()

        # Open file if specified and stdout is not piped
        if debug and debug_file and not stdout_is_piped:
            from pathlib import Path

            Path(debug_file).parent.mkdir(parents=True, exist_ok=True)
            self.file_handle = open(debug_file, "w", encoding="utf-8")
            # Also create a console that writes to file (without colors/styling)
            self.file_console = Console(file=self.file_handle, force_terminal=False)
        else:
            self.file_console = None

    def __del__(self):
        """Close file handle on cleanup."""
        if self.file_handle:
            self.file_handle.close()

    def _print(self, *args, **kwargs):
        """Print to both console and file if available."""
        if self.console:
            self.console.print(*args, **kwargs)
        if self.file_console:
            # Strip rich markup for file output - use file_console which handles this
            self.file_console.print(*args, **kwargs)

    def phase(self, phase_name: str, description: str = ""):
        """Start a new phase section (only for the 3 main phases)."""
        if not self.debug:
            return
        self.phase_num += 1
        self._print()
        self._print(f"[bold cyan]{'='*80}[/bold cyan]")
        self._print(f"[bold cyan]PHASE {self.phase_num}: {phase_name}[/bold cyan]")
        if description:
            self._print(f"[dim cyan]{description}[/dim cyan]")
        self._print(f"[bold cyan]{'='*80}[/bold cyan]")

    def attempt_header(self, attempt_num: int, description: str = ""):
        """Show an attempt header without incrementing phase number (sub-section of Phase 1)."""
        if not self.debug:
            return
        self._print()
        self._print(
            "[dim]────────────────────────────────────────────────────────────────────────────────[/dim]"
        )
        self._print(f"[bold]Attempt {attempt_num}[/bold]")

    def info(self, message: str, indent: int = 0):
        """Print informational message."""
        if not self.debug:
            return
        prefix = "  " * indent
        self._print(f"{prefix}[dim]{message}[/dim]")

    def data(self, label: str, value: Any, truncate: int = None):
        """Print data with label-value format."""
        if not self.debug:
            return
        if truncate and isinstance(value, str) and len(value) > truncate:
            display_value = value[:truncate] + "..."
        else:
            display_value = value
        self._print(f"  [yellow]{label}:[/yellow] {display_value}")

    def decision(self, title: str, details: str):
        """Print a decision point."""
        if not self.debug:
            return
        self._print()
        self._print(f"[bold magenta]🔀 DECISION: {title}[/bold magenta]")
        self._print(f"  [dim]{details}[/dim]")

    def llm_call(
        self,
        purpose: str,
        input_data: str = None,
        output_data: Any = None,
        cost: float = None,
        input_tokens: int = None,
        output_tokens: int = None,
        model: str = None,
    ):
        """Show LLM call with input/output, cost, token usage, and model information."""
        if not self.debug:
            return
        self._print()
        self._print(f"[bold green]🤖 LLM CALL: {purpose}[/bold green]")
        if model:
            self._print(f"  [yellow]🤖 Model: {model}[/yellow]")
        if input_data:
            self._print("  [dim]Input:[/dim]")
            # Truncate long inputs
            if len(input_data) > 500:
                display_input = (
                    input_data[:500] + f"\n  ... ({len(input_data) - 500} more chars)"
                )
            else:
                display_input = input_data
            self._print(f"    [dim]{display_input}[/dim]")
        if output_data:
            if isinstance(output_data, str):
                # For Cypher queries (containing MATCH, RETURN, etc.), show more context
                if "MATCH" in output_data.upper() or "RETURN" in output_data.upper():
                    # For Cypher queries, show up to 1000 chars (they're important)
                    if len(output_data) > 1000:
                        display_output = (
                            output_data[:1000]
                            + f"\n  ... ({len(output_data) - 1000} more chars)"
                        )
                    else:
                        display_output = output_data
                else:
                    # Don't truncate - show full output
                    display_output = output_data
                self._print(f"  [dim]Output:[/dim] {display_output}")
            elif isinstance(output_data, dict):
                # For dict output (like Cypher query results), format nicely
                self._print("  [dim]Output:[/dim]")
                for key, value in output_data.items():
                    if key == "query" and isinstance(value, str):
                        # Show full Cypher query (it's already important)
                        if len(value) > 1000:
                            query_preview = (
                                value[:1000]
                                + f"\n    ... ({len(value) - 1000} more chars)"
                            )
                        else:
                            query_preview = value
                        self._print(f"    [cyan]{key}:[/cyan] {query_preview}")
                    elif isinstance(value, str):
                        # Don't truncate - show full value
                        self._print(f"    [cyan]{key}:[/cyan] {value}")
                    else:
                        self._print(f"    [cyan]{key}:[/cyan] {value}")
            else:
                self._print(f"  [dim]Output:[/dim] {output_data}")

        # Always show cost and token info if available
        if cost is not None:
            self._print(f"  [green]💵 Cost: ${cost:.6f}[/green]")
        if input_tokens is not None or output_tokens is not None:
            token_info = []
            if input_tokens is not None:
                token_info.append(f"{input_tokens:,} input")
            if output_tokens is not None:
                token_info.append(f"{output_tokens:,} output")
            if token_info:
                total_tokens = (input_tokens or 0) + (output_tokens or 0)
                self._print(
                    f"  [cyan]🔢 Tokens: {', '.join(token_info)} (total: {total_tokens:,})[/cyan]"
                )

    def deepeval(self, result: Any, show_as_phase: bool = True):
        """Show DeepEval evaluation results.

        Args:
            result: Evaluation result object
            show_as_phase: If True, show as a separate Phase 3. If False, show as part of Phase 2.
                          Default is True to show DeepEval as Phase 3.
        """
        if not self.debug:
            return
        self._print()
        if show_as_phase:
            self._print(f"[bold blue]{'='*80}[/bold blue]")
            self._print("[bold blue]PHASE 3: DeepEval Evaluation[/bold blue]")
            self._print(
                "[bold blue]DeepEval checks the enhanced answer quality[/bold blue]"
            )
            self._print(f"[bold blue]{'='*80}[/bold blue]")
        else:
            self._print("[bold blue]📊 DeepEval EVALUATION (Phase 3)[/bold blue]")
            self._print("  [dim]Evaluating Phase 2 answer quality...[/dim]")

        if hasattr(result, "pattern_detected"):
            self._print(
                f"  [cyan]Pattern Detected:[/cyan] {result.pattern_detected or 'None'}"
            )
        if hasattr(result, "score"):
            self._print(f"  [cyan]Overall Score:[/cyan] {result.score:.3f}")
        if hasattr(result, "passed"):
            status = "[green]PASSED[/green]" if result.passed else "[red]FAILED[/red]"
            self._print(f"  [cyan]Status:[/cyan] {status}")
        if hasattr(result, "metrics"):
            self._print(f"  [cyan]Metrics:[/cyan] {result.metrics}")
        if hasattr(result, "issues") and result.issues:
            self._print(f"  [cyan]Issues:[/cyan] {len(result.issues)}")
            for issue in result.issues[:5]:  # Show first 5 issues
                self._print(f"    [dim]- {issue}[/dim]")

    def query_execution(
        self, cypher: str, parameters: Dict = None, results_count: int = None
    ):
        """Show Cypher query execution."""
        if not self.debug:
            return
        self._print()
        self._print("[bold yellow]🔍 DATABASE QUERY EXECUTION[/bold yellow]")
        # Show FULL query with syntax highlighting (not truncated)
        syntax = Syntax(
            cypher, "cypher", theme="monokai", line_numbers=False, word_wrap=True
        )
        self._print(syntax)
        if parameters:
            self._print(f"  [dim]Parameters:[/dim] {parameters}")
        if results_count is not None:
            if results_count == 0:
                self._print(
                    f"  [red]Results: {results_count} record(s) ⚠️  No results found[/red]"
                )
            else:
                self._print(f"  [green]Results: {results_count} record(s)[/green]")

    def validation(self, validation_result: Any):
        """Show validation results."""
        if not self.debug:
            return
        self._print()
        self._print("[bold magenta]✓ VALIDATION[/bold magenta]")
        if hasattr(validation_result, "is_valid"):
            status = (
                "[green]VALID[/green]"
                if validation_result.is_valid
                else "[red]INVALID[/red]"
            )
            self._print(f"  [cyan]Status:[/cyan] {status}")
        if hasattr(validation_result, "confidence"):
            self._print(
                f"  [cyan]Confidence:[/cyan] {validation_result.confidence:.3f}"
            )
        if hasattr(validation_result, "expected_types"):
            self._print(
                f"  [cyan]Expected Types:[/cyan] {list(validation_result.expected_types)}"
            )
        if hasattr(validation_result, "actual_types"):
            self._print(
                f"  [cyan]Actual Types:[/cyan] {list(validation_result.actual_types)}"
            )

    def warning(self, message: str):
        """Print warning message."""
        if not self.debug:
            return
        self._print(f"  [yellow]⚠️  {message}[/yellow]")

    def success(self, message: str):
        """Print success message."""
        if not self.debug:
            return
        self._print(f"  [green]✅ {message}[/green]")

    def error(self, message: str):
        """Print error message."""
        if not self.debug:
            return
        self._print(f"  [red]❌ {message}[/red]")


@dataclass
class LLMResult:
    """Result of LLM orchestrator processing."""

    question: str
    cypher_query: str
    raw_data: List[Dict[str, Any]]
    enhanced_answer: str
    execution_time: float
    success: bool
    error: Optional[str] = None
    # LLM generation metadata (optional, come after required fields)
    llm_cost_usd: float | None = None
    llm_tokens_used: int | None = None


class LLMOrchestrator:
    """Main orchestrator for LLM-first query processing."""

    def __init__(
        self, db: Neo4jConnection, debug: bool = False, debug_file: str = None
    ):
        """Initialize the LLM orchestrator.

        Args:
            db: Neo4j database connection
            debug: Enable debug output for evaluation and decisions
            debug_file: Optional path to file to save debug output
        """
        self.db = db
        self.debug = debug
        self.debug_formatter = DebugFormatter(debug=debug, debug_file=debug_file)
        self.cypher_generator = LangChainCypherGenerator(neo4j_uri=db.uri)
        # Initialize evaluator (lazy init, can work without API key)
        # COST OPTIMIZATION: Phase 3 is opt-in by default (disabled for cost savings)
        phase3_enabled = (
            os.getenv("PHASE3_EVALUATION_ENABLED", "false").lower() == "true"
        )
        try:
            from .evaluator import QueryEvaluator

            self.evaluator = QueryEvaluator(
                enabled=phase3_enabled, lazy_init=True, debug=debug
            )
            if debug and phase3_enabled:
                self.debug_formatter.info("Phase 3 (DeepEval) evaluation enabled")
            elif debug and not phase3_enabled:
                self.debug_formatter.info(
                    "Phase 3 (DeepEval) evaluation disabled (cost optimization). Set PHASE3_EVALUATION_ENABLED=true to enable."
                )
        except ImportError:
            self.evaluator = None
            if debug:
                self.debug_formatter.warning(
                    "DeepEval not available - evaluation disabled"
                )
        self.query_validator = QueryValidator()
        # TODO: Add LLM enhancer when we build it
        self.llm_enhancer = None

    def process_question(self, question: str, limit: int = 10) -> LLMResult:
        """
        Process a natural language question through the complete pipeline with 3-attempt retry.

        Attempt 1: Normal query generation
        Attempt 2: Fix/relax query based on error feedback
        Attempt 3: Simplify dramatically to basic pattern

        Args:
            question: Natural language question

        Returns:
            LLMResult with all processing steps and final answer
        """
        start_time = time.time()
        attempts = []

        # Initialize debug output
        self.debug_formatter.phase(
            "Query Generation",
            "Question → LLM (Langchain) → Cypher Query → Database",
        )
        self.debug_formatter.data("Question", question)
        self.debug_formatter.data("Limit", limit)

        # Validate question is not a placeholder/example
        import re

        question_lower = question.lower().strip()
        placeholder_phrases = [
            "your question here",
            "insert question here",
            "enter question here",
            "type question here",
            "example question",
            "test question",
            "sample question",
            "placeholder",
            "type your question",
            "question goes here",
            "ask a question",
            "what is your question",
            "please enter",
            "example",
            "test",
            "sample",
        ]

        # Also check for patterns like "insert/enter/type" + "question/query"
        placeholder_patterns = [
            r"\b(insert|enter|type|add|put)\s+(your\s+)?(question|query|text)\s+(here|below|above)\b",
            r"\b(question|query)\s+(here|below|above|to\s+start)\b",
            r"^\s*(example|test|sample|placeholder|demo)\s*(question|query)?\s*$",
        ]

        is_placeholder = (
            any(phrase in question_lower for phrase in placeholder_phrases)
            or question_lower in ["", "?", "??", "???", "test", "example", "sample"]
            or any(
                re.search(pattern, question_lower) for pattern in placeholder_patterns
            )
            or (
                len(question_lower) < 10
                and any(
                    word in question_lower
                    for word in [
                        "question",
                        "query",
                        "ask",
                        "example",
                        "test",
                        "sample",
                        "insert",
                        "enter",
                        "type",
                    ]
                )
            )
        )

        if is_placeholder:
            error_msg = (
                "This appears to be a placeholder or example question, not a real query.\n"
                "Please provide an actual cybersecurity question, such as:\n"
                "  - 'What are the most critical CVEs from 2024?'\n"
                "  - 'Show me XSS vulnerabilities'\n"
                "  - 'What is CWE-79?'\n"
                "  - 'Explain buffer overflow attacks'"
            )
            self.debug_formatter.error(error_msg)
            return LLMResult(
                question=question,
                cypher_query="",
                raw_data=[],
                enhanced_answer="",
                execution_time=time.time() - start_time,
                success=False,
                error=error_msg,
            )

        # Check for help requests or questions about CLAIRE
        # Only trigger if it's clearly about the system itself, not cybersecurity topics
        simple_help = question_lower in [
            "help",
            "?",
            "help me",
            "show help",
            "what is claire",
            "what is claire-kg",
        ]
        system_help = any(
            phrase in question_lower
            for phrase in [
                "how to use",
                "how does this work",
                "what can you do",
                "how do i use",
                "what is this",
                "what does this do",
                "how does claire work",
                "what is claire",
                "tell me about claire",
                "explain claire",
                "information about claire",
            ]
        )
        # Combined help + claire keywords (but not if it's about cybersecurity topics)
        help_keywords = [
            "help",
            "what is",
            "how does",
            "how do",
            "what does",
            "explain",
            "tell me about",
            "information about",
        ]
        claire_keywords = [
            "claire",
            "claire-kg",
            "this system",
            "this tool",
            "you",
            "your purpose",
        ]
        combined_help = (
            any(help_kw in question_lower for help_kw in help_keywords)
            and any(claire_kw in question_lower for claire_kw in claire_keywords)
            and
            # Exclude if it contains cybersecurity entity keywords (not about CLAIRE)
            not any(
                entity in question_lower
                for entity in [
                    "cve",
                    "cwe",
                    "capec",
                    "attack",
                    "vulnerability",
                    "weakness",
                    "technique",
                    "tactic",
                ]
            )
        )

        is_help_request = simple_help or system_help or combined_help

        if is_help_request:
            help_msg = """CLAIRE-KG Help

What is CLAIRE-KG?
CLAIRE-KG is a cybersecurity knowledge graph that answers questions using data from:
  • CVE (Common Vulnerabilities and Exposures)
  • CWE (Common Weakness Enumeration)
  • CAPEC (Common Attack Pattern Enumeration and Classification)
  • MITRE ATT&CK Framework
  • NICE Framework (workforce roles, skills, knowledge)
  • DCWF (DoD Cyber Workforce Framework)

How to use:
Ask cybersecurity questions in natural language, such as:
  • 'What are the most critical CVEs from 2024?'
  • 'Show me XSS vulnerabilities'
  • 'What is CWE-79 (Cross-site Scripting)?'
  • 'Explain buffer overflow attacks'
  • 'What are the skills needed to defend against SQL injection?'
  • 'Show me CVEs related to CWE-79'
  • 'What attack patterns exploit buffer overflows?'
  • 'What work roles are involved in vulnerability assessment?'

For more information:
  Run 'uv run python -m claire_kg.cli --help' for all commands
  Run 'uv run python -m claire_kg.cli test debug-help' for debug help"""

            self.debug_formatter.info(
                "Help request detected - showing CLAIRE-KG information"
            )
            self.debug_formatter.data("Help Message", help_msg)
            return LLMResult(
                question=question,
                cypher_query="",
                raw_data=[],
                enhanced_answer=help_msg,
                execution_time=time.time() - start_time,
                success=True,  # Help requests are successful responses
                error=None,
            )

        # Check if user explicitly asked to NOT use the database
        ignore_database_phrases = [
            "don't use the database",
            "do not use the database",
            "ignore the database",
            "without database",
            "use general knowledge",
            "use your general knowledge",
            "don't use database",
            "skip database",
            # CLAIRE-specific variations
            "don't use claire",
            "do not use claire",
            "ignore claire",
            "skip claire",
            "without claire",
            "don't use claire-kg",
            "skip claire-kg",
            "ignore claire-kg",
        ]
        should_ignore_database = any(
            phrase in question_lower for phrase in ignore_database_phrases
        )

        # If user asked to ignore database, skip Phase 1 entirely
        if should_ignore_database:
            # Go directly to Phase 2 with empty results
            enhanced_answer = self._enhance_with_llm_phase2(
                question=question,
                raw_data=[],
                cypher_query="SKIPPED - User requested to not use database",
                pagination_info=None,
                validation=None,
            )

            # Create a result with no database query
            result = LLMResult(
                question=question,
                cypher_query="SKIPPED - User requested to not use database",
                raw_data=[],
                enhanced_answer=enhanced_answer,
                execution_time=time.time() - start_time,
                success=True,
                error=None,
            )
            return result

        # Pre-execution Pattern F check: If it's a correlation question, use Pattern F query directly
        question_lower = question.lower()
        correlation_keywords = [
            "correlation",
            "relationship between",
            "compare",
            "correlate",
        ]
        is_correlation_question = any(
            kw in question_lower for kw in correlation_keywords
        )

        # For Q100-style questions: correlation between vulnerability severity and workforce expertise
        if (
            is_correlation_question
            and "vulnerability" in question_lower
            and "severity" in question_lower
            and ("workforce" in question_lower or "expertise" in question_lower)
        ):
            if self.debug:
                print(
                    "\n[DEBUG] Pre-execution Pattern F detection: Using correlation query directly"
                )

            # Use Pattern F query directly for this specific pattern
            pattern_f_query = """MATCH (v:Vulnerability)
WHERE v.severity IS NOT NULL AND v.severity <> ''
WITH v.severity AS severity_level, v
MATCH (v)-[:HAS_WEAKNESS]->(w:Weakness)
MATCH (ap:AttackPattern)-[:EXPLOITS]->(w)
MATCH (ap)-[:RELATES_TO]->(t:Technique)
MATCH (wr:WorkRole)-[:WORKS_WITH]->(t)
RETURN severity_level AS uid, 
       severity_level AS title, 
       'CVEs: ' + toString(count(DISTINCT v)) + ', WorkRoles: ' + toString(count(DISTINCT wr)) AS text
ORDER BY severity_level
LIMIT $limit"""

            try:
                pattern_f_data = self.db.execute_cypher(
                    pattern_f_query, {"limit": limit}
                )
                if pattern_f_data is None:
                    pattern_f_data = []

                if pattern_f_data and len(pattern_f_data) > 0:
                    if self.debug:
                        print(
                            f"   ✅ Pattern F query executed: {len(pattern_f_data)} results"
                        )

                    # Build Phase 1 JSON with Pattern F results
                    pattern_f_pagination = self._build_pagination_info(
                        pattern_f_query, pattern_f_data
                    )
                    pattern_f_validation = self._validate_result(
                        type(
                            "obj",
                            (object,),
                            {
                                "cypher_query": pattern_f_query,
                                "raw_data": pattern_f_data,
                                "question": question,
                            },
                        )(),
                        question,
                    )
                    pattern_f_phase1_json = self._prepare_phase1_json_output(
                        question=question,
                        raw_data=pattern_f_data,
                        cypher_query=pattern_f_query,
                        pagination_info=pattern_f_pagination,
                        validation=pattern_f_validation,
                    )

                    # Run Phase 2
                    pattern_f_answer = self._enhance_with_llm_phase2_from_json(
                        pattern_f_phase1_json
                    )

                    # Create result
                    result = LLMResult(
                        question=question,
                        cypher_query=pattern_f_query,
                        raw_data=pattern_f_data,
                        enhanced_answer=pattern_f_answer,
                        execution_time=time.time() - start_time,
                        success=True,
                        error=None,
                    )

                    self.debug_formatter.success("Pattern F pre-execution successful!")
                    return result
            except Exception as e:
                self.debug_formatter.warning(
                    f"Pattern F pre-execution failed: {e}, falling back to normal query generation"
                )

        # Attempt 1: Normal query generation
        result = self._attempt_query(
            question,
            attempt_num=1,
            previous_error=None,
            previous_query=None,
            limit=limit,
        )
        attempts.append(result)

        # Validate result (check if entity types match expected types)
        validation = self._validate_result(result, question)
        # Consider valid only if high confidence (>= 0.9) - lower confidence means partial/wrong match
        is_high_confidence = validation.is_valid and validation.confidence >= 0.9

        if (
            result.success
            and result.raw_data
            and len(result.raw_data) > 0
            and is_high_confidence
        ):
            # Success on first try!
            result.execution_time = time.time() - start_time

            # Phase 2: Generate final enhanced answer
            if result.raw_data:
                self.debug_formatter.phase(
                    "LLM Answer Enhancement",
                    "LLM transforms database results into human-readable answer with citations",
                )
                pagination_info = self._build_pagination_info(
                    result.cypher_query, result.raw_data
                )
                # Use Phase 1 → Phase 2 JSON flow for consistency (includes evaluation)
                phase1_json = self._prepare_phase1_json_output(
                    question=question,
                    raw_data=result.raw_data,
                    cypher_query=result.cypher_query,
                    pagination_info=pagination_info,
                    validation=validation,
                )
                self.debug_formatter.data(
                    "Phase 1 JSON prepared", f"{len(result.raw_data)} results"
                )

                # Get Phase 2 model (will be shown after the actual call completes)
                phase2_model_preview = os.getenv("PHASE2_MODEL", "gpt-3.5-turbo")
                self.debug_formatter.llm_call(
                    "Enhance Answer with Citations (Phase 2)",
                    input_data=f"Question: {question}\nResults: {len(result.raw_data)} records",
                    model=phase2_model_preview,  # Preview model before call
                )
                phase2_answer = self._enhance_with_llm_phase2_from_json(phase1_json)
                result.enhanced_answer = phase2_answer
                # Note: Cost/token info for Phase 2 LLM call is shown inside _enhance_with_llm_phase2_from_json

                # Phase 3: DeepEval Integration - Evaluate Phase 2 answer quality
                # Skip DeepEval if Phase 1 had no results - can't evaluate an answer without source data
                if (
                    self.evaluator
                    and self.evaluator.enabled
                    and result.raw_data
                    and len(result.raw_data) > 0
                ):
                    self.debug_formatter.phase(
                        "DeepEval Evaluation",
                        "DeepEval checks the enhanced answer quality",
                    )
                    try:
                        eval_result = self.evaluator.evaluate(
                            question=question,
                            answer=phase2_answer,
                            phase1_json=phase1_json,
                        )
                        self.debug_formatter.deepeval(eval_result, show_as_phase=True)

                        # Auto-regenerate if Pattern C detected
                        if eval_result.pattern_detected == "Pattern C":
                            regenerated = self._regenerate_for_pattern_c(
                                question=question,
                                result=result,
                                phase1_json=phase1_json,
                                eval_result=eval_result,
                            )
                            if regenerated:
                                # Regeneration successful, use regenerated result
                                result = regenerated
                        # Auto-regenerate if Pattern D detected (temporal queries)
                        elif eval_result.pattern_detected == "Pattern D":
                            regenerated = self._regenerate_for_pattern_d(
                                question=question,
                                result=result,
                                phase1_json=phase1_json,
                                eval_result=eval_result,
                            )
                            if regenerated:
                                # Regeneration successful, use regenerated result
                                result = regenerated
                        # Auto-regenerate if Pattern E detected (CVE -> Skills multi-hop queries)
                        elif eval_result.pattern_detected == "Pattern E":
                            regenerated = self._regenerate_for_pattern_e(
                                question=question,
                                result=result,
                                phase1_json=phase1_json,
                                eval_result=eval_result,
                            )
                            if regenerated:
                                # Regeneration successful, use regenerated result
                                result = regenerated
                        # Auto-regenerate if Pattern F detected (correlation questions missing GROUP BY)
                        elif eval_result.pattern_detected == "Pattern F":
                            regenerated = self._regenerate_for_pattern_f(
                                question=question,
                                result=result,
                                phase1_json=phase1_json,
                                eval_result=eval_result,
                            )
                            if regenerated:
                                # Regeneration successful, use regenerated result
                                result = regenerated

                        # Quick Pattern F check even if evaluation fails or pattern not detected
                        question_lower = question.lower()
                        correlation_keywords = [
                            "correlation",
                            "relationship between",
                            "compare",
                            "correlate",
                        ]
                        is_correlation_question = any(
                            kw in question_lower for kw in correlation_keywords
                        )

                        if is_correlation_question and result.cypher_query:
                            cypher_upper = result.cypher_query.upper()
                            uses_union_search = (
                                "UNION" in cypher_upper and "CONTAINS" in cypher_upper
                            )
                            has_group_by = "GROUP BY" in cypher_upper
                            has_aggregation = any(
                                agg in cypher_upper
                                for agg in ["COUNT(", "AVG(", "SUM("]
                            )

                            if (
                                uses_union_search
                                or (not has_group_by)
                                or (has_group_by and not has_aggregation)
                            ):
                                self.debug_formatter.decision(
                                    "Pattern F Auto-Detection",
                                    "Pattern F detected in Attempt 1 - auto-regenerating",
                                )
                                eval_result_mock = type(
                                    "obj", (object,), {"pattern_detected": "Pattern F"}
                                )()
                                regenerated = self._regenerate_for_pattern_f(
                                    question=question,
                                    result=result,
                                    phase1_json=phase1_json,
                                    eval_result=eval_result_mock,
                                )
                                if regenerated:
                                    result = regenerated
                    except Exception as e:
                        if self.debug:
                            print(f"⚠️  Evaluation failed (Attempt 1): {e}")
                            import traceback

                            traceback.print_exc()

            return result
        elif result.success and result.raw_data and len(result.raw_data) > 0:
            # Has results but validation failed or low confidence - treat as invalid
            if not result.error:
                if not validation.is_valid:
                    result.error = (
                        validation.mismatch_reason
                        or "Query returned wrong entity types"
                    )
                elif validation.confidence < 0.9:
                    if validation.expected_types:
                        primary = max(
                            validation.expected_types,
                            key=lambda t: {
                                "Knowledge": 10,
                                "Skill": 9,
                                "Task": 8,
                                "WorkRole": 7,
                            }.get(t, 0),
                        )
                        result.error = f"Query returned partial match (confidence: {validation.confidence:.2f}). Expected primary type {primary} but got {validation.actual_types}."
                    else:
                        result.error = f"Query returned partial match (confidence: {validation.confidence:.2f}). Got {validation.actual_types} but expected types could not be determined from the question."

        # Pre-retry check: Detect common query logic errors before attempt 2
        # This helps catch issues like: Technique {name: 'Execution'} when Execution is a Tactic
        should_fix_tactic_query = False
        if (
            result.success
            and result.cypher_query
            and (
                len(result.raw_data) == 0
                or (
                    result.raw_data
                    and len(result.raw_data) == 1
                    and result.raw_data[0].get("total_intersecting_roles") == 0
                )
            )
        ):
            # Query executed but returned 0 or wrong results
            # Check if it's incorrectly querying Technique with a Tactic name
            query_lower = result.cypher_query.lower()
            question_lower = question.lower()

            # Common Tactic names that might be confused
            tactic_names = [
                "execution",
                "persistence",
                "privilege escalation",
                "defense evasion",
                "credential access",
                "discovery",
                "lateral movement",
                "collection",
                "exfiltration",
                "command and control",
                "impact",
                "initial access",
            ]

            # Check if question mentions a tactic and query uses Technique {name: 'TacticName'}
            import re

            for tactic in tactic_names:
                if tactic in question_lower:
                    # Check if query has pattern: Technique {name: 'TacticName'}
                    # This is wrong - should use USES_TACTIC relationship
                    # Escape curly braces in regex pattern
                    pattern = (
                        r"technique\s*\{[^}]*name\s*:\s*['\"]?"
                        + re.escape(tactic)
                        + r"['\"]?"
                    )
                    if re.search(pattern, query_lower):
                        should_fix_tactic_query = True
                        break

        # Attempt 2: Fix/relax query (if failed, no results, or validation failed)
        validation_msg = ""
        if validation and not validation.is_valid:
            validation_msg = f"\nVALIDATION ERROR: {validation.mismatch_reason}"

        # Check for Skill vs WorkRole mismatch (even if validation passed with low confidence)
        if validation and result.raw_data:
            expected_types = validation.expected_types
            actual_types = validation.actual_types
            question_lower = question.lower()
            if self.debug:
                self.debug_formatter.info(
                    "Checking for Skill vs WorkRole type mismatches..."
                )
                self.debug_formatter.data(
                    "Expected Types", list(expected_types) if expected_types else "None"
                )
                self.debug_formatter.data(
                    "Actual Types", list(actual_types) if actual_types else "None"
                )
            if (
                "Skill" in expected_types
                and "WorkRole" in actual_types
                and "Skill" not in actual_types
            ):
                # Question asks for Skills but query returned WorkRoles
                if self.debug:
                    print("  ✅ SKILL/WORKROLE MISMATCH DETECTED - Adding feedback!")
                validation_msg += (
                    "\n\n🔴 CRITICAL VALIDATION MISMATCH: Question asks for 'skills' but query returned 'WorkRoles'!\n"
                    "These are DIFFERENT entity types:\n"
                    "- Skills: Specific competencies (e.g., 'Python Programming', 'Network Analysis')\n"
                    "- WorkRoles: Job roles (e.g., 'Cyber Defense Analyst', 'Penetration Tester')\n"
                    "You MUST traverse to Skill nodes, not WorkRole nodes!"
                )
            # Also check for CVE/Vulnerability in actual when Skills are expected
            elif (
                "Skill" in expected_types
                and ("Vulnerability" in actual_types or "Weakness" in actual_types)
                and "Skill" not in actual_types
            ):
                if self.debug:
                    print(
                        "  ✅ SKILL/CVE MISMATCH DETECTED - Question asks for Skills but query returned CVEs/Weaknesses!"
                    )
                validation_msg += (
                    "\n\n🔴 CRITICAL VALIDATION MISMATCH: Question asks for 'skills' but query returned 'Vulnerabilities' or 'Weaknesses'!\n"
                    "You MUST traverse the complete path to reach Skill nodes:\n"
                    "CVE -> CWE -> CAPEC -> ATT&CK -> WorkRole -> Skill\n"
                    "DO NOT return CVEs or CWEs - you must complete the full traversal!"
                )

        error_msg = (
            result.error
            or validation_msg
            or ("No results returned" if result.success else "Query execution failed")
        )

        # Add specific fix for Tactic vs Technique confusion
        if should_fix_tactic_query:
            # Find which tactic was mentioned
            tactic_mentioned = None
            for tactic in [
                "execution",
                "persistence",
                "privilege escalation",
                "defense evasion",
                "credential access",
                "discovery",
                "lateral movement",
                "collection",
                "exfiltration",
                "command and control",
                "impact",
                "initial access",
            ]:
                if tactic in question.lower():
                    tactic_mentioned = tactic
                    break

            if tactic_mentioned:
                error_msg += (
                    f"\n\n🔴 CRITICAL QUERY LOGIC ERROR: '{tactic_mentioned.title()}' is a TACTIC name, not a Technique name!\n"
                    f"You are using: (t:Technique {{name: '{tactic_mentioned}'}})\n"
                    f"This is WRONG. You MUST use: (t:Technique)-[:USES_TACTIC]->(ta:Tactic)\n"
                    f"WHERE toLower(ta.name) CONTAINS '{tactic_mentioned}'\n"
                    f"Example: MATCH (wr:WorkRole)-[:WORKS_WITH]->(t:Technique)-[:USES_TACTIC]->(ta:Tactic)\n"
                    f"         WHERE toLower(ta.name) CONTAINS '{tactic_mentioned}'\n"
                    f"         RETURN COUNT(DISTINCT wr) AS count"
                )
        if not result.cypher_query:
            # If we don't have a query from attempt 1, use original question with error context
            relaxed_question = f"{question}\n\nNote: Previous attempt failed with: {error_msg}. Please generate a working query."
        else:
            relaxed_question = self._create_relaxed_query(
                question,
                error_msg,
                result.cypher_query,
                attempt=2,
                validation=validation,
            )
        result = self._attempt_query(
            relaxed_question,  # Use relaxed_question (with error feedback) not original question
            attempt_num=2,
            previous_error=error_msg,
            previous_query=result.cypher_query,
            limit=limit,
        )
        attempts.append(result)

        # Validate attempt 2
        validation = self._validate_result(result, question)
        if self.debug:
            self.debug_formatter.info("Validating Attempt 2 results...")
            self.debug_formatter.validation(validation)
        is_high_confidence = validation.is_valid and validation.confidence >= 0.9
        if (
            result.success
            and result.raw_data
            and len(result.raw_data) > 0
            and is_high_confidence
        ):
            result.execution_time = time.time() - start_time

            # Phase 2: Generate final enhanced answer
            if result.raw_data:
                if self.debug:
                    self.debug_formatter.phase(
                        "LLM Answer Enhancement",
                        "LLM transforms database results into human-readable answer with citations",
                    )
                pagination_info = self._build_pagination_info(
                    result.cypher_query, result.raw_data
                )
                # Use Phase 1 → Phase 2 JSON flow for consistency (includes evaluation)
                phase1_json = self._prepare_phase1_json_output(
                    question=question,
                    raw_data=result.raw_data,
                    cypher_query=result.cypher_query,
                    pagination_info=pagination_info,
                    validation=validation,
                )
                phase2_answer = self._enhance_with_llm_phase2_from_json(phase1_json)
                result.enhanced_answer = phase2_answer

                # Phase 3: DeepEval Integration - Evaluate Phase 2 answer quality
                # Skip DeepEval if Phase 1 had no results
                if (
                    self.evaluator
                    and self.evaluator.enabled
                    and result.raw_data
                    and len(result.raw_data) > 0
                ):
                    if self.debug:
                        self.debug_formatter.phase(
                            "DeepEval Evaluation",
                            "DeepEval checks the enhanced answer quality",
                        )
                    try:
                        eval_result = self.evaluator.evaluate(
                            question=question,
                            answer=phase2_answer,
                            phase1_json=phase1_json,
                        )
                        if self.debug:
                            self.debug_formatter.deepeval(
                                eval_result, show_as_phase=True
                            )

                        # Auto-regenerate if Pattern C detected
                        if eval_result.pattern_detected == "Pattern C":
                            regenerated = self._regenerate_for_pattern_c(
                                question=question,
                                result=result,
                                phase1_json=phase1_json,
                                eval_result=eval_result,
                            )
                            if regenerated:
                                # Regeneration successful, use regenerated result
                                result = regenerated
                        # Auto-regenerate if Pattern D detected (temporal queries)
                        elif eval_result.pattern_detected == "Pattern D":
                            regenerated = self._regenerate_for_pattern_d(
                                question=question,
                                result=result,
                                phase1_json=phase1_json,
                                eval_result=eval_result,
                            )
                            if regenerated:
                                # Regeneration successful, use regenerated result
                                result = regenerated
                        # Auto-regenerate if Pattern E detected (CVE -> Skills multi-hop queries)
                        elif eval_result.pattern_detected == "Pattern E":
                            regenerated = self._regenerate_for_pattern_e(
                                question=question,
                                result=result,
                                phase1_json=phase1_json,
                                eval_result=eval_result,
                            )
                            if regenerated:
                                # Regeneration successful, use regenerated result
                                result = regenerated
                        # Auto-regenerate if Pattern F detected (correlation questions missing GROUP BY)
                        elif eval_result.pattern_detected == "Pattern F":
                            regenerated = self._regenerate_for_pattern_f(
                                question=question,
                                result=result,
                                phase1_json=phase1_json,
                                eval_result=eval_result,
                            )
                            if regenerated:
                                # Regeneration successful, use regenerated result
                                result = regenerated

                        # Quick Pattern F check even if evaluation fails or pattern not detected
                        question_lower = question.lower()
                        correlation_keywords = [
                            "correlation",
                            "relationship between",
                            "compare",
                            "correlate",
                        ]
                        is_correlation_question = any(
                            kw in question_lower for kw in correlation_keywords
                        )

                        if is_correlation_question and result.cypher_query:
                            cypher_upper = result.cypher_query.upper()
                            uses_union_search = (
                                "UNION" in cypher_upper and "CONTAINS" in cypher_upper
                            )
                            has_group_by = "GROUP BY" in cypher_upper
                            has_aggregation = any(
                                agg in cypher_upper
                                for agg in ["COUNT(", "AVG(", "SUM("]
                            )

                            if (
                                uses_union_search
                                or (not has_group_by)
                                or (has_group_by and not has_aggregation)
                            ):
                                if self.debug:
                                    print(
                                        "\n[DEBUG] Pattern F detected in Attempt 2 - auto-regenerating..."
                                    )
                                eval_result_mock = type(
                                    "obj", (object,), {"pattern_detected": "Pattern F"}
                                )()
                                regenerated = self._regenerate_for_pattern_f(
                                    question=question,
                                    result=result,
                                    phase1_json=phase1_json,
                                    eval_result=eval_result_mock,
                                )
                                if regenerated:
                                    result = regenerated
                    except Exception as e:
                        if self.debug:
                            print(f"⚠️  Evaluation failed (Attempt 2): {e}")
                            import traceback

                            traceback.print_exc()

            return result

        # Continue to attempt 3 if we got here (low confidence or validation failed)
        if self.debug:
            self.debug_formatter.decision(
                "Attempt 2 Decision",
                f"Did NOT pass high confidence check (confidence: {validation.confidence:.2f}) - continuing to Attempt 3",
            )
            self.debug_formatter.data("Success", result.success)
            self.debug_formatter.data(
                "Results Count", len(result.raw_data) if result.raw_data else 0
            )
            self.debug_formatter.data("Validation Valid", validation.is_valid)
            self.debug_formatter.data("Confidence", f"{validation.confidence:.2f}")
            self.debug_formatter.data("High Confidence Threshold", "≥ 0.9")

        if result.success and result.raw_data and len(result.raw_data) > 0:
            # Has results but validation failed or low confidence
            if not result.error:
                if not validation.is_valid:
                    result.error = (
                        validation.mismatch_reason
                        or "Query returned wrong entity types"
                    )
                elif validation.confidence < 0.9:
                    if validation.expected_types:
                        primary = max(
                            validation.expected_types,
                            key=lambda t: {
                                "Knowledge": 10,
                                "Skill": 9,
                                "Task": 8,
                                "WorkRole": 7,
                            }.get(t, 0),
                        )
                        result.error = f"Query returned partial match (confidence: {validation.confidence:.2f}). Expected primary type {primary} but got {validation.actual_types}."
                    else:
                        result.error = f"Query returned partial match (confidence: {validation.confidence:.2f}). Got {validation.actual_types} but expected types could not be determined from the question."

        # Attempt 3: Simplify dramatically (if still failed, no results, or validation failed)
        if self.debug:
            self.debug_formatter.info("Starting Attempt 3...")
        validation2 = self._validate_result(result, question)
        validation_msg2 = ""
        if validation2 and not validation2.is_valid:
            validation_msg2 = f"\nVALIDATION ERROR: {validation2.mismatch_reason}"
        error_msg = (
            result.error
            or validation_msg2
            or ("No results returned" if result.success else "Query execution failed")
        )
        if not result.cypher_query:
            simple_question = self._create_relaxed_query(
                question, error_msg, None, attempt=3, validation=validation2
            )
        else:
            simple_question = self._create_relaxed_query(
                question,
                error_msg,
                result.cypher_query,
                attempt=3,
                validation=validation2,
            )
        result = self._attempt_query(
            simple_question,  # Use simple_question (with error feedback) not original question
            attempt_num=3,
            previous_error=error_msg,
            previous_query=result.cypher_query,
            limit=limit,
        )
        attempts.append(result)

        # Check for Pattern E and F immediately after attempt 3 (before Phase 2)
        # This catches patterns even if attempt 3 fails (check query structure)
        if result.cypher_query:  # Check even if failed, as long as there's a query
            # Prepare phase1_json even if result failed (need it for pattern detection)
            attempt3_raw_data = result.raw_data if result.raw_data else []
            attempt3_validation = self._validate_result(result, question)
            attempt3_pagination = self._build_pagination_info(
                result.cypher_query, attempt3_raw_data
            )
            attempt3_phase1_json = self._prepare_phase1_json_output(
                question=question,
                raw_data=attempt3_raw_data,
                cypher_query=result.cypher_query,
                pagination_info=attempt3_pagination,
                validation=attempt3_validation,
            )

            if self.evaluator and self.evaluator.enabled:
                try:
                    # Quick Pattern E check (just pattern detection, not full evaluation)
                    question_lower = question.lower()
                    cve_skills_keywords = [
                        "skill",
                        "skills",
                        "workforce skill",
                        "workforce skills",
                    ]
                    cve_keywords = [
                        "cve",
                        "vulnerability",
                        "vulnerabilities",
                        "top 10 cve",
                    ]
                    is_cve_skills = any(
                        kw in question_lower for kw in cve_skills_keywords
                    ) and any(kw in question_lower for kw in cve_keywords)

                    if is_cve_skills:
                        cypher_upper = (result.cypher_query or "").upper()
                        uses_union = (
                            "UNION" in cypher_upper and "CONTAINS" in cypher_upper
                        )
                        has_full_path = (
                            "HAS_WEAKNESS" in cypher_upper
                            and "EXPLOITS" in cypher_upper
                            and "RELATES_TO" in cypher_upper
                            and "WORKS_WITH" in cypher_upper
                            and "REQUIRES_SKILL" in cypher_upper
                        )

                        if uses_union or not has_full_path:
                            # Pattern E detected - regenerate
                            eval_result_mock = type(
                                "obj", (object,), {"pattern_detected": "Pattern E"}
                            )()
                            regenerated = self._regenerate_for_pattern_e(
                                question=question,
                                result=result,
                                phase1_json=attempt3_phase1_json,
                                eval_result=eval_result_mock,
                            )
                            if regenerated:
                                result = regenerated
                                attempts[-1] = (
                                    result  # Update last attempt with regenerated result
                                )

                    # Quick Pattern F check (correlation questions)
                    correlation_keywords = [
                        "correlation",
                        "relationship between",
                        "compare",
                        "correlate",
                    ]
                    is_correlation = any(
                        kw in question_lower for kw in correlation_keywords
                    )

                    if is_correlation:
                        cypher_upper = (result.cypher_query or "").upper()
                        uses_union_search = (
                            "UNION" in cypher_upper and "CONTAINS" in cypher_upper
                        )
                        has_group_by = "GROUP BY" in cypher_upper
                        has_aggregation = any(
                            agg in cypher_upper for agg in ["COUNT(", "AVG(", "SUM("]
                        )

                        if self.debug:
                            print(
                                f"\n[DEBUG] Pattern F check: uses_union={uses_union_search}, "
                                f"has_group_by={has_group_by}, has_aggregation={has_aggregation}"
                            )

                        if (
                            uses_union_search
                            or (not has_group_by)
                            or (has_group_by and not has_aggregation)
                        ):
                            # Pattern F detected - regenerate
                            if self.debug:
                                print("   ✅ Pattern F detected - regenerating...")
                            eval_result_mock = type(
                                "obj", (object,), {"pattern_detected": "Pattern F"}
                            )()
                            regenerated = self._regenerate_for_pattern_f(
                                question=question,
                                result=result,
                                phase1_json=attempt3_phase1_json,
                                eval_result=eval_result_mock,
                            )
                            if regenerated:
                                result = regenerated
                                attempts[-1] = (
                                    result  # Update last attempt with regenerated result
                                )
                except Exception as e:
                    if self.debug:
                        print(f"⚠️  Pattern E/F pre-check failed: {e}")

        # Return the best result (prefer one with data, even if not perfect)
        best_result = max(
            attempts, key=lambda r: (r.success, len(r.raw_data) if r.raw_data else 0)
        )
        best_result.execution_time = time.time() - start_time

        # Debug: Show final decision
        if self.debug:
            self.debug_formatter.decision(
                "Final Result Selection",
                f"Selecting best result from {len(attempts)} attempt(s)",
            )
            self.debug_formatter.decision(
                "Best Result Selected",
                f"Success: {best_result.success}, Results: {len(best_result.raw_data) if best_result.raw_data else 0}, "
                f"Has Error: {bool(best_result.error)}",
            )
            if best_result.error:
                self.debug_formatter.warning(f"Final error: {best_result.error}")
            if not best_result.raw_data or len(best_result.raw_data) == 0:
                self.debug_formatter.warning(
                    "⚠️  No results found after all attempts - Phase 2 will be skipped"
                )
                self.debug_formatter.info("Summary of attempts:")
                for i, attempt in enumerate(attempts, 1):
                    result_count = len(attempt.raw_data) if attempt.raw_data else 0
                    status = "✅ Success" if attempt.success else "❌ Failed"
                    self.debug_formatter.info(
                        f"  Attempt {i}: {status}, {result_count} results", indent=1
                    )

        # Phase 2: Generate final enhanced answer with LLM (with citations)
        # Phase 1 produces JSON, Phase 2 creates human-readable answer
        if best_result.raw_data and best_result.success:
            final_validation = self._validate_result(best_result, question)
            pagination_info = self._build_pagination_info(
                best_result.cypher_query, best_result.raw_data
            )

            # Phase 1: Create JSON output structure
            phase1_json = self._prepare_phase1_json_output(
                question=question,
                raw_data=best_result.raw_data,
                cypher_query=best_result.cypher_query,
                pagination_info=pagination_info,
                validation=final_validation,
            )

            # Phase 2: Use JSON to generate human-readable answer with citations
            try:
                if self.debug:
                    self.debug_formatter.phase(
                        "LLM Answer Enhancement",
                        "LLM transforms database results into human-readable answer with citations",
                    )
                    self.debug_formatter.info(
                        f"Proceeding to Phase 2 with {len(best_result.raw_data)} results",
                        indent=1,
                    )
                phase2_answer = self._enhance_with_llm_phase2_from_json(phase1_json)
                best_result.enhanced_answer = phase2_answer
                if self.debug:
                    self.debug_formatter.success(
                        "Phase 2 completed - answer generated with citations"
                    )

                # Phase 3: DeepEval Integration - Evaluate Phase 2 answer quality
                # Skip DeepEval if Phase 1 had no results
                if (
                    self.evaluator
                    and self.evaluator.enabled
                    and best_result.raw_data
                    and len(best_result.raw_data) > 0
                ):
                    if self.debug:
                        self.debug_formatter.phase(
                            "DeepEval Evaluation",
                            "DeepEval checks the enhanced answer quality",
                        )

                    try:
                        eval_result = self.evaluator.evaluate(
                            question=question,
                            answer=phase2_answer,
                            phase1_json=phase1_json,
                        )

                        if self.debug:
                            self.debug_formatter.deepeval(
                                eval_result, show_as_phase=True
                            )

                        # Auto-regenerate if Pattern C detected (counting query)
                        # Pattern C detection means "counting question returned entities instead of count"
                        # We should ALWAYS regenerate when Pattern C is detected, regardless of evaluation score
                        if eval_result.pattern_detected == "Pattern C":
                            regenerated = self._regenerate_for_pattern_c(
                                question=question,
                                result=best_result,
                                phase1_json=phase1_json,
                                eval_result=eval_result,
                            )
                            if regenerated:
                                # Regeneration successful, use regenerated result
                                best_result = regenerated
                        # Auto-regenerate if Pattern D detected (temporal queries)
                        elif eval_result.pattern_detected == "Pattern D":
                            regenerated = self._regenerate_for_pattern_d(
                                question=question,
                                result=best_result,
                                phase1_json=phase1_json,
                                eval_result=eval_result,
                            )
                            if regenerated:
                                # Regeneration successful, use regenerated result
                                best_result = regenerated
                        # Auto-regenerate if Pattern E detected (CVE -> Skills multi-hop queries)
                        elif eval_result.pattern_detected == "Pattern E":
                            regenerated = self._regenerate_for_pattern_e(
                                question=question,
                                result=best_result,
                                phase1_json=phase1_json,
                                eval_result=eval_result,
                            )
                            if regenerated:
                                # Regeneration successful, use regenerated result
                                best_result = regenerated
                        # Auto-regenerate if Pattern F detected (correlation questions missing GROUP BY)
                        elif eval_result.pattern_detected == "Pattern F":
                            regenerated = self._regenerate_for_pattern_f(
                                question=question,
                                result=best_result,
                                phase1_json=phase1_json,
                                eval_result=eval_result,
                            )
                            if regenerated:
                                # Regeneration successful, use regenerated result
                                best_result = regenerated
                        elif eval_result.pattern_detected:
                            if self.debug:
                                print(
                                    f"\n⚠️  Pattern {eval_result.pattern_detected} detected but not auto-fixed yet."
                                )

                    except Exception as e:
                        if self.debug:
                            print(f"⚠️  Evaluation failed: {e}")
                            import traceback

                            traceback.print_exc()
                        # Don't fail the whole query if evaluation fails
                        pass

            except Exception as e:
                # If Phase 2 fails, keep Phase 1 result
                if self.debug:
                    self.debug_formatter.error(f"Phase 2 enhancement failed: {e}")
                    import traceback

                    traceback.print_exc()
                else:
                    print(f"⚠️  Phase 2 enhancement failed: {e}")
                pass  # Keep the Phase 1 minimal answer
        else:
            # No results after all attempts - provide informative message
            if self.debug:
                self.debug_formatter.warning(
                    "Phase 2 skipped - no results found after all query attempts"
                )
                if best_result.error:
                    self.debug_formatter.info(
                        f"Final error message: {best_result.error}"
                    )
                else:
                    self.debug_formatter.info("No specific error message available")

                # Try to provide helpful diagnostic
                if best_result.cypher_query:
                    self.debug_formatter.info("Consider checking:", indent=1)
                    self.debug_formatter.info(
                        "  • Does the entity type exist in the database?", indent=1
                    )
                    self.debug_formatter.info(
                        "  • Are property names correct (e.g., 'title' vs 'name')?",
                        indent=1,
                    )
                    self.debug_formatter.info(
                        "  • Are relationship names correct?", indent=1
                    )
                    self.debug_formatter.info(
                        "  • Try a more general query or different entity type",
                        indent=1,
                    )

        return best_result

    def _regenerate_for_pattern_c(
        self,
        question: str,
        result: LLMResult,
        phase1_json: Dict[str, Any],
        eval_result: Any,
    ) -> Optional[LLMResult]:
        """
        Regenerate query and answer for Pattern C (counting queries returning entities).

        Args:
            question: Original question
            result: Current LLMResult (will be updated in place)
            phase1_json: Phase 1 JSON output
            eval_result: Evaluation result containing pattern detection

        Returns:
            Updated LLMResult if regeneration successful, None otherwise
        """
        if self.debug:
            print("\n🔄 Auto-Regenerating Query for Pattern C...")
            print("   Issue: Counting question returned entities instead of count")

        try:
            if self.debug:
                print("   🔄 Regenerating Cypher query with COUNT aggregation...")

            # Add instruction to the question for regeneration
            enhanced_question = f"{question}\n\nIMPORTANT: This is a COUNT question. Use RETURN count(...) AS count, NOT individual entities. Do not use LIMIT."

            # Generate new Cypher query with COUNT instruction
            cypher_result = self.cypher_generator.generate_cypher(
                enhanced_question,
                limit=999999,  # Effectively no limit for counting
            )

            # Ensure the query uses COUNT
            new_cypher = cypher_result.query
            if "return count(" not in new_cypher.lower():
                # Manually fix if LLM didn't follow instruction
                if self.debug:
                    print("   ⚠️  LLM didn't use COUNT, fixing query manually...")
                # Extract the MATCH/WHERE part and replace RETURN with COUNT
                import re

                match_part = re.search(
                    r"(MATCH.*?)(?:\s+RETURN|\s+return)",
                    new_cypher,
                    re.DOTALL | re.IGNORECASE,
                )
                if match_part:
                    new_cypher = match_part.group(1) + " RETURN count(*) AS count"

            if self.debug:
                print(f"   ✅ New Query: {new_cypher[:100]}...")

            # Execute the regenerated query
            parameters = cypher_result.parameters
            regenerated_data = self.db.execute_cypher(new_cypher, parameters)

            if regenerated_data is None:
                regenerated_data = []

            if self.debug:
                print(
                    f"   📊 Regenerated Query Results: {len(regenerated_data)} count value(s)"
                )

            # Re-run Phase 1 JSON preparation with regenerated data
            regenerated_pagination = self._build_pagination_info(
                new_cypher, regenerated_data
            )
            regenerated_validation = self._validate_result(
                type(
                    "obj",
                    (object,),
                    {
                        "cypher_query": new_cypher,
                        "raw_data": regenerated_data,
                        "question": question,
                    },
                )(),
                question,
            )
            regenerated_phase1_json = self._prepare_phase1_json_output(
                question=question,
                raw_data=regenerated_data,
                cypher_query=new_cypher,
                pagination_info=regenerated_pagination,
                validation=regenerated_validation,
            )

            # Re-run Phase 2 with regenerated results
            if self.debug:
                print("   🎨 Re-running Phase 2 enhancement with count result...")

            regenerated_answer = self._enhance_with_llm_phase2_from_json(
                regenerated_phase1_json
            )

            # Update result in place
            result.enhanced_answer = regenerated_answer
            result.cypher_query = new_cypher
            result.raw_data = regenerated_data

            if self.debug:
                print("   ✅ Regeneration successful! Answer now contains count.")

            return result

        except Exception as regen_error:
            if self.debug:
                print(f"   ❌ Regeneration failed: {regen_error}")
                import traceback

                traceback.print_exc()
            # Keep original answer if regeneration fails
            return None

    def _regenerate_for_pattern_d(
        self,
        question: str,
        result: LLMResult,
        phase1_json: Dict[str, Any],
        eval_result: Any,
    ) -> Optional[LLMResult]:
        """
        Regenerate query and answer for Pattern D (temporal queries missing ORDER BY).

        Args:
            question: Original question
            result: Current LLMResult (will be updated in place)
            phase1_json: Phase 1 JSON output
            eval_result: Evaluation result containing pattern detection

        Returns:
            Updated LLMResult if regeneration successful, None otherwise
        """
        if self.debug:
            print("\n🔄 Auto-Regenerating Query for Pattern D...")
            print("   Issue: Temporal question missing ORDER BY clause")

        try:
            if self.debug:
                print("   🔄 Regenerating Cypher query with ORDER BY clause...")

            # Determine ordering direction and field from question
            question_lower = question.lower()

            # Determine sort direction
            if any(
                kw in question_lower
                for kw in ["most recent", "latest", "newest", "last", "recent"]
            ):
                sort_direction = "DESC"  # Most recent = descending by date
                sort_description = "most recent"
            elif any(
                kw in question_lower
                for kw in ["oldest", "earliest", "first", "earliest"]
            ):
                sort_direction = "ASC"  # Oldest = ascending by date
                sort_description = "oldest"
            else:
                sort_direction = "DESC"  # Default to most recent
                sort_description = "most recent"

            # Determine what field to sort by (usually date-related)
            # Check if question mentions year, published date, etc.
            if (
                "year" in question_lower
                or "published" in question_lower
                or "2024" in question_lower
                or "2023" in question_lower
            ):
                # For CVEs, use published date or year
                sort_field = "v.year"  # Will be adjusted based on node type
            else:
                # Default to year or published_date
                sort_field = "v.year"

            # Add instruction to the question for regeneration
            enhanced_question = f"""{question}

IMPORTANT: This is a TEMPORAL/ORDERING question. You MUST include an ORDER BY clause to sort results correctly.
- Use ORDER BY with the appropriate date/year field ({sort_description})
- Sort direction: {sort_direction}
- Common fields: year, published_date, created_date, discovery_date
- For "most recent", use ORDER BY ... DESC
- For "oldest" or "earliest", use ORDER BY ... ASC"""

            # Generate new Cypher query with ORDER BY instruction
            cypher_result = self.cypher_generator.generate_cypher(
                enhanced_question,
                limit=(
                    result.raw_data.__len__() if result.raw_data else 10
                ),  # Keep same limit
            )

            # Ensure the query uses ORDER BY
            new_cypher = cypher_result.query
            if "order by" not in new_cypher.lower():
                # Manually fix if LLM didn't follow instruction
                if self.debug:
                    print("   ⚠️  LLM didn't use ORDER BY, fixing query manually...")
                # Try to add ORDER BY before LIMIT
                import re

                # Check what type of node we're querying to determine sort field
                # Vulnerability nodes: use year (extracted from CVE ID) or published date
                if (
                    "(v:vulnerability)" in new_cypher.lower()
                    or ":vulnerability" in new_cypher.lower()
                ):
                    # For CVEs, year is extracted from CVE ID format (CVE-YYYY-NNNNN)
                    # Prefer year, fallback to published date if year not available
                    sort_field = "v.year"
                    # Note: v.published exists but ordering by year DESC is sufficient for "most recent"
                # Weakness nodes (CWEs): CWEs don't have year, use uid for ordering
                elif (
                    "(w:weakness)" in new_cypher.lower()
                    or ":weakness" in new_cypher.lower()
                ):
                    sort_field = "w.uid"  # CWE IDs like CWE-79 don't have year field
                # AttackPattern nodes (CAPEC): use uid for ordering
                elif (
                    "(ap:attackpattern)" in new_cypher.lower()
                    or ":attackpattern" in new_cypher.lower()
                ):
                    sort_field = "ap.uid"
                # Technique nodes (ATT&CK): use uid for ordering
                elif (
                    "(t:technique)" in new_cypher.lower()
                    or ":technique" in new_cypher.lower()
                ):
                    sort_field = "t.uid"
                # WorkRole nodes: use uid for ordering
                elif (
                    "(wr:workrole)" in new_cypher.lower()
                    or ":workrole" in new_cypher.lower()
                ):
                    sort_field = "wr.uid"
                else:
                    # Generic fallback: try to find any node variable and use year or uid
                    import re

                    node_match = re.search(r"\((\w+):\w+\)", new_cypher, re.IGNORECASE)
                    if node_match:
                        node_var = node_match.group(1)
                        sort_field = (
                            f"{node_var}.year"
                            if "year" in new_cypher.lower()
                            else f"{node_var}.uid"
                        )
                    else:
                        sort_field = "n.year"  # Last resort

                # Insert ORDER BY before LIMIT
                if "limit" in new_cypher.lower():
                    new_cypher = re.sub(
                        r"(\s+LIMIT\s+[^\s]+)",
                        f" ORDER BY {sort_field} {sort_direction}\\1",
                        new_cypher,
                        flags=re.IGNORECASE,
                    )
                else:
                    # No LIMIT, add ORDER BY at end
                    new_cypher = (
                        new_cypher.rstrip() + f" ORDER BY {sort_field} {sort_direction}"
                    )

            if self.debug:
                print(f"   ✅ New Query: {new_cypher[:150]}...")

            # Execute the regenerated query
            parameters = cypher_result.parameters
            regenerated_data = self.db.execute_cypher(new_cypher, parameters)

            if regenerated_data is None:
                regenerated_data = []

            if self.debug:
                print(
                    f"   📊 Regenerated Query Results: {len(regenerated_data)} result(s)"
                )

            # Re-run Phase 1 JSON preparation with regenerated data
            regenerated_pagination = self._build_pagination_info(
                new_cypher, regenerated_data
            )
            regenerated_validation = self._validate_result(
                type(
                    "obj",
                    (object,),
                    {
                        "cypher_query": new_cypher,
                        "raw_data": regenerated_data,
                        "question": question,
                    },
                )(),
                question,
            )
            regenerated_phase1_json = self._prepare_phase1_json_output(
                question=question,
                raw_data=regenerated_data,
                cypher_query=new_cypher,
                pagination_info=regenerated_pagination,
                validation=regenerated_validation,
            )

            # Re-run Phase 2 with regenerated results
            if self.debug:
                print("   🎨 Re-running Phase 2 enhancement with ordered results...")

            regenerated_answer = self._enhance_with_llm_phase2_from_json(
                regenerated_phase1_json
            )

            # Update result in place
            result.enhanced_answer = regenerated_answer
            result.cypher_query = new_cypher
            result.raw_data = regenerated_data

            if self.debug:
                print("   ✅ Regeneration successful! Query now includes ORDER BY.")

            return result

        except Exception as regen_error:
            if self.debug:
                print(f"   ❌ Regeneration failed: {regen_error}")
                import traceback

                traceback.print_exc()
            # Keep original answer if regeneration fails
            return None

    def _regenerate_for_pattern_e(
        self,
        question: str,
        result: LLMResult,
        phase1_json: Dict[str, Any],
        eval_result: Any,
    ) -> Optional[LLMResult]:
        """
        Regenerate query and answer for Pattern E (CVE -> Skills multi-hop traversal).

        Pattern E: Questions asking for "skills needed to defend against CVEs" require:
        CVE -> CWE -> CAPEC -> ATT&CK -> WorkRole -> Skill

        This method constructs the correct multi-hop traversal query.

        Args:
            question: Original question
            result: Current LLMResult (will be updated in place)
            phase1_json: Phase 1 JSON output
            eval_result: Evaluation result containing pattern detection

        Returns:
            Updated LLMResult if regeneration successful, None otherwise
        """
        if self.debug:
            print("\n🔄 Auto-Regenerating Query for Pattern E...")
            print(
                "   Issue: CVE->Skills question needs complete multi-hop traversal path"
            )

        try:
            # Construct the correct multi-hop traversal query directly
            # This is too complex for the LLM to get right via feedback, so we build it ourselves
            if self.debug:
                print("   🔄 Building correct CVE->Skills traversal query...")

            # Extract year from question if mentioned, otherwise use 2024
            import re

            year_match = re.search(r"20\d{2}", question)
            target_year = int(year_match.group()) if year_match else 2024

            # Build the complete traversal query
            # Simplify ORDER BY - just use year for now (top 10 by year is sufficient)
            # The CVSS ordering is complex and can cause syntax errors
            new_cypher = f"""MATCH (v:Vulnerability)
WHERE v.year = {target_year}
WITH v ORDER BY v.year DESC, v.uid DESC
LIMIT 10
MATCH (v)-[:HAS_WEAKNESS]->(w:Weakness)
MATCH (ap:AttackPattern)-[:EXPLOITS]->(w)
MATCH (ap)-[:RELATES_TO]->(t:Technique)
MATCH (wr:WorkRole)-[:WORKS_WITH]->(t)
MATCH (wr)-[:REQUIRES_SKILL]->(s:Skill)
RETURN DISTINCT s.uid AS uid, s.name AS title, s.description AS text
ORDER BY s.name
LIMIT $limit"""

            if self.debug:
                print("   ✅ Generated correct traversal query")
                print(f"   Query preview: {new_cypher[:200]}...")

            # Execute the regenerated query
            try:
                regenerated_data = self.db.execute_cypher(
                    new_cypher,
                    {"limit": result.raw_data.__len__() if result.raw_data else 10},
                )
            except Exception as query_error:
                if self.debug:
                    print(f"   ❌ Query execution failed: {query_error}")
                # If query fails, return None to keep original result
                return None

            if regenerated_data is None:
                regenerated_data = []

            if self.debug:
                print(
                    f"   📊 Regenerated Query Results: {len(regenerated_data)} result(s)"
                )
                if len(regenerated_data) == 0:
                    print(
                        "   ⚠️  Warning: Path traversal returned 0 results - this may be a data limitation"
                    )
                    print(
                        "      (No Skills connected through: CVE -> CWE -> CAPEC -> ATT&CK -> WorkRole -> Skill)"
                    )

            # Re-run Phase 1 JSON preparation with regenerated data
            regenerated_pagination = self._build_pagination_info(
                new_cypher, regenerated_data
            )
            regenerated_validation = self._validate_result(
                type(
                    "obj",
                    (object,),
                    {
                        "cypher_query": new_cypher,
                        "raw_data": regenerated_data,
                        "question": question,
                    },
                )(),
                question,
            )
            regenerated_phase1_json = self._prepare_phase1_json_output(
                question=question,
                raw_data=regenerated_data,
                cypher_query=new_cypher,
                pagination_info=regenerated_pagination,
                validation=regenerated_validation,
            )

            # Re-run Phase 2 with regenerated results
            if self.debug:
                print("   🎨 Re-running Phase 2 enhancement with Skills results...")

            regenerated_answer = self._enhance_with_llm_phase2_from_json(
                regenerated_phase1_json
            )

            # Update result in place
            result.enhanced_answer = regenerated_answer
            result.cypher_query = new_cypher
            result.raw_data = regenerated_data

            if self.debug:
                print(
                    "   ✅ Regeneration successful! Query now uses complete traversal path."
                )

            return result

        except Exception as regen_error:
            if self.debug:
                print(f"   ❌ Regeneration failed: {regen_error}")
                import traceback

                traceback.print_exc()
            # Keep original answer if regeneration fails
            return None

    def _regenerate_for_pattern_f(
        self,
        question: str,
        result: LLMResult,
        phase1_json: Dict[str, Any],
        eval_result: Any,
    ) -> Optional[LLMResult]:
        """
        Regenerate query and answer for Pattern F (correlation questions missing GROUP BY/aggregation).

        Pattern F: Questions asking for "correlation" or "relationship between" require:
        - GROUP BY aggregation
        - Analytical queries showing relationships/patterns
        - Not just listing entities

        Args:
            question: Original question
            result: Current LLMResult (will be updated in place)
            phase1_json: Phase 1 JSON output
            eval_result: Evaluation result containing pattern detection

        Returns:
            Updated LLMResult if regeneration successful, None otherwise
        """
        if self.debug:
            print("\n🔄 Auto-Regenerating Query for Pattern F...")
            print("   Issue: Correlation question needs GROUP BY aggregation")

        try:
            question_lower = question.lower()

            # For Q100: "correlation between vulnerability severity and workforce expertise"
            if (
                "vulnerability" in question_lower
                and "severity" in question_lower
                and ("workforce" in question_lower or "expertise" in question_lower)
            ):
                if self.debug:
                    print(
                        "   🔄 Building correlation query: severity -> workforce expertise"
                    )

                # Build correlation query: group by severity, count WorkRoles
                new_cypher = """MATCH (v:Vulnerability)
WHERE v.severity IS NOT NULL AND v.severity <> ''
WITH v.severity AS severity_level, v
MATCH (v)-[:HAS_WEAKNESS]->(w:Weakness)
MATCH (ap:AttackPattern)-[:EXPLOITS]->(w)
MATCH (ap)-[:RELATES_TO]->(t:Technique)
MATCH (wr:WorkRole)-[:WORKS_WITH]->(t)
RETURN severity_level AS uid, 
       severity_level AS title, 
       'CVEs: ' + toString(count(DISTINCT v)) + ', WorkRoles: ' + toString(count(DISTINCT wr)) AS text
ORDER BY severity_level
LIMIT $limit"""

                if self.debug:
                    print("   ✅ Generated correlation query")
                    print(f"   Query preview: {new_cypher[:200]}...")

                # Execute the regenerated query
                try:
                    regenerated_data = self.db.execute_cypher(
                        new_cypher,
                        {"limit": result.raw_data.__len__() if result.raw_data else 10},
                    )
                except Exception as query_error:
                    if self.debug:
                        print(f"   ❌ Query execution failed: {query_error}")
                    return None

                if regenerated_data is None:
                    regenerated_data = []

                if self.debug:
                    print(
                        f"   📊 Regenerated Query Results: {len(regenerated_data)} result(s)"
                    )

                # Re-run Phase 1 JSON preparation
                regenerated_pagination = self._build_pagination_info(
                    new_cypher, regenerated_data
                )
                regenerated_validation = self._validate_result(
                    type(
                        "obj",
                        (object,),
                        {
                            "cypher_query": new_cypher,
                            "raw_data": regenerated_data,
                            "question": question,
                        },
                    )(),
                    question,
                )
                regenerated_phase1_json = self._prepare_phase1_json_output(
                    question=question,
                    raw_data=regenerated_data,
                    cypher_query=new_cypher,
                    pagination_info=regenerated_pagination,
                    validation=regenerated_validation,
                )

                # Re-run Phase 2 with regenerated results
                if self.debug:
                    print(
                        "   🎨 Re-running Phase 2 enhancement with correlation results..."
                    )

                regenerated_answer = self._enhance_with_llm_phase2_from_json(
                    regenerated_phase1_json
                )

                # Update result in place
                result.enhanced_answer = regenerated_answer
                result.cypher_query = new_cypher
                result.raw_data = regenerated_data

                if self.debug:
                    print(
                        "   ✅ Regeneration successful! Query now uses GROUP BY aggregation."
                    )

                return result
            else:
                # Generic correlation - return None to let feedback guide LLM
                if self.debug:
                    print(
                        "   ⚠️  Generic correlation pattern - letting feedback guide LLM"
                    )
                return None

        except Exception as regen_error:
            if self.debug:
                print(f"   ❌ Regeneration failed: {regen_error}")
                import traceback

                traceback.print_exc()
            return None

    def _fix_count_syntax_errors(self, cypher_query: str, question: str) -> str:
        """
        Pre-execution syntax fix: Fix common COUNT syntax errors before query execution.

        This catches issues like:
        - Missing RETURN before COUNT: "COUNT(...)" -> "RETURN COUNT(...)"
        - COUNT in wrong position in UNION queries

        Args:
            cypher_query: Original Cypher query
            question: Original question (to detect counting questions)

        Returns:
            Fixed Cypher query (unchanged if no fixes needed)
        """
        import re

        fixed_query = cypher_query
        query_lower = cypher_query.lower()
        question_lower = question.lower()

        # Fix 1: Missing RETURN before COUNT
        # Pattern: MATCH ... COUNT(...) AS ... (missing RETURN)
        # Should be: MATCH ... RETURN COUNT(...) AS ...

        # Check if COUNT appears without RETURN before it (in the first MATCH clause)
        # Pattern: MATCH ... [optional WHERE/other clauses] COUNT(...)
        if "count(" in query_lower:
            # Find where COUNT appears
            count_match = re.search(r"COUNT\s*\(", fixed_query, re.IGNORECASE)
            if count_match:
                count_pos = count_match.start()
                # Check what comes before COUNT - should be RETURN but might be missing
                before_count = fixed_query[:count_pos].rstrip()

                # Check if RETURN exists before this COUNT
                # Look backwards from COUNT position for RETURN
                return_before_count = False
                for keyword in ["RETURN", "return"]:
                    if keyword in before_count:
                        # Check if this RETURN is actually before COUNT (not in a different branch)
                        # Simple check: if RETURN appears and is on same "line" level
                        return_before_count = True
                        break

                if not return_before_count:
                    # No RETURN before COUNT - need to add it
                    # Find the end of the MATCH/WHERE clause before COUNT
                    # Pattern: MATCH ... [optional WHERE] COUNT -> MATCH ... [optional WHERE] RETURN COUNT
                    # Use a more permissive pattern that handles multi-line queries
                    pattern = r"((?:MATCH|WHERE|WITH)[^C]*?)(?=\s+COUNT\s*\()"
                    match = re.search(
                        pattern, fixed_query[:count_pos], re.IGNORECASE | re.DOTALL
                    )
                    if match:
                        # Found MATCH/WHERE before COUNT, insert RETURN
                        insert_pos = match.end()
                        fixed_query = (
                            fixed_query[:insert_pos]
                            + " RETURN "
                            + fixed_query[insert_pos:]
                        )
                    else:
                        # Fallback: just insert RETURN before COUNT
                        fixed_query = (
                            fixed_query[:count_pos]
                            + "RETURN "
                            + fixed_query[count_pos:]
                        )

        # Handle UNION queries: each branch needs its own RETURN
        # Fix any UNION branches that have COUNT without RETURN
        if "union" in query_lower and "count(" in query_lower:
            # For UNION queries, fix each branch separately
            # Pattern: UNION ... COUNT(...) -> UNION ... RETURN COUNT(...)
            branches = re.split(r"\s+UNION\s+", fixed_query, flags=re.IGNORECASE)
            fixed_branches = []
            for i, branch in enumerate(branches):
                if i == 0:
                    # First branch (no UNION prefix)
                    fixed_branches.append(branch)
                else:
                    # Subsequent branches (need UNION prefix)
                    branch_lower = branch.lower()
                    if "count(" in branch_lower and "return" not in branch_lower:
                        # This UNION branch needs RETURN before COUNT
                        count_pos = re.search(r"COUNT\s*\(", branch, re.IGNORECASE)
                        if count_pos:
                            branch = (
                                branch[: count_pos.start()]
                                + " RETURN "
                                + branch[count_pos.start() :]
                            )
                    fixed_branches.append(" UNION " + branch)
            fixed_query = "".join(fixed_branches)

        # Fix 2: For counting questions, ensure we're using COUNT not returning entities
        # This is a pre-execution check - Pattern C will handle regeneration if needed
        is_counting_question = any(
            kw in question_lower
            for kw in ["how many", "count", "number of", "total number"]
        )

        if is_counting_question and "return count(" not in fixed_query.lower():
            # Counting question but not using COUNT - this will be caught by Pattern C
            # But we can at least ensure syntax is correct if COUNT is present
            pass  # Pattern C will handle the regeneration

        return fixed_query

    def _fix_with_clause_scope_errors(self, cypher_query: str) -> str:
        """
        Fix WITH clause variable scope errors.

        Common error: Using variables in RETURN that weren't included in WITH clause.
        Example: MATCH (a:A) WITH COUNT(a) AS c RETURN a.field  -- ERROR: 'a' not in WITH
        Fix: Detect if variables used in RETURN are not in WITH, and either:
          - Remove the variable from RETURN if it's not needed
          - Or add it to WITH clause

        Args:
            cypher_query: Original Cypher query

        Returns:
            Fixed Cypher query (unchanged if no fixes needed)
        """
        import re

        # Check if query has WITH clause
        if " with " not in cypher_query.lower():
            return cypher_query  # No WITH clause, nothing to fix

        # Split query into parts: before WITH, WITH clause, after WITH
        with_match = re.search(r"\s+WITH\s+", cypher_query, re.IGNORECASE)
        if not with_match:
            return cypher_query

        with_pos = with_match.start()
        before_with = cypher_query[:with_pos]
        after_with = cypher_query[with_pos + with_match.end() :]

        # Extract variables used in MATCH before WITH
        match_vars = re.findall(r"\((\w+):\w+\)", before_with, re.IGNORECASE)
        match_vars = list(set(match_vars))  # Get unique variable names

        # Extract variables/properties in WITH clause
        # Pattern: WITH var1, var2 AS alias, COUNT(var3) AS count
        with_vars_raw = re.search(
            r"WITH\s+(.+?)(?:\s+MATCH|\s+RETURN|\s+WHERE|\s+UNION|$)",
            after_with,
            re.IGNORECASE | re.DOTALL,
        )
        if not with_vars_raw:
            return cypher_query

        with_content = with_vars_raw.group(1)
        # Extract variables from WITH (both direct and in expressions)
        with_vars_in_expressions = re.findall(
            r"\b([a-z]\w*)\b", with_content, re.IGNORECASE
        )

        # Find RETURN clause
        return_match = re.search(
            r"\s+RETURN\s+(.+?)(?:\s+LIMIT|\s+UNION|$)",
            cypher_query,
            re.IGNORECASE | re.DOTALL,
        )
        if not return_match:
            return cypher_query

        return_content = return_match.group(1)
        # Extract variables used in RETURN (e.g., v.uid, w.name)
        return_var_pattern = r"\b([a-z]\w*)\."
        return_vars = re.findall(return_var_pattern, return_content, re.IGNORECASE)

        # Check if any RETURN variables are not in WITH clause
        undefined_vars = []
        for ret_var in return_vars:
            if (
                ret_var not in with_content.lower()
                and ret_var not in with_vars_in_expressions
            ):
                # Check if this variable was in the MATCH clause (meaning it should be in WITH)
                if ret_var.lower() in [v.lower() for v in match_vars]:
                    undefined_vars.append(ret_var)

        if undefined_vars and len(undefined_vars) > 0:
            # Variables used in RETURN but not in WITH - try to fix
            # For questions about "mitigations", we probably don't need the original MATCH variables
            # But this is complex - for now, we'll let attempt 2 handle it with better error feedback
            # Just return original query and let the error feedback guide the LLM
            pass  # Pre-execution fix is complex, let error feedback handle it

        return cypher_query  # Return unchanged for now - let error feedback on attempt 2 handle it

    def _fix_nonexistent_relationships_for_mitigations(
        self, cypher_query: str, question: str
    ) -> str:
        """
        Pre-execution fix: Remove non-existent relationships for mitigation questions.

        Fixes queries that use relationships like :IS_SQL_INJECTION or :SQLInjection
        which don't exist in the database. For mitigation questions, these should
        be replaced with the correct path: Vulnerability -[:HAS_WEAKNESS]-> Weakness.

        Args:
            cypher_query: Cypher query that may have wrong relationships
            question: Original question

        Returns:
            Fixed query with correct relationships
        """
        import re

        question_lower = question.lower()
        mitigation_keywords = [
            "mitigation",
            "mitigate",
            "mitigates",
            "addresses",
            "address",
        ]
        is_mitigation_question = any(kw in question_lower for kw in mitigation_keywords)

        if not is_mitigation_question:
            return cypher_query

        # Fix non-existent relationships
        fixed_query = cypher_query

        # Fix :IS_SQL_INJECTION or :SQLInjection (doesn't exist)
        # Check for any variation of this non-existent relationship or node type
        query_upper = fixed_query.upper()
        has_sql_injection_issue = (
            ":IS_SQL_INJECTION" in query_upper
            or ":SQLInjection" in fixed_query
            or ":SQLINJECTION" in query_upper
            or ":SQL_INJECTION" in query_upper
            or re.search(
                r":SQLInjection|:SQLINJECTION|:IS_SQL_INJECTION",
                fixed_query,
                re.IGNORECASE,
            )
            or re.search(r"\([^)]*:SQLInjection[^)]*\)", fixed_query, re.IGNORECASE)
        )

        if has_sql_injection_issue:
            # Pattern 2 FIRST: Double relationship like MATCH (v)-[:IS_SQL_INJECTION]->(si:SQLInjection)<-[:IS_SQL_INJECTION]-(m)
            # Check this FIRST before simpler patterns, as it's the most complex
            if re.search(
                r":IS_SQL_INJECTION.*:IS_SQL_INJECTION", fixed_query, re.IGNORECASE
            ):
                fixed_query = re.sub(
                    r"MATCH\s+\(v:Vulnerability\)\s*-\s*\[:IS_SQL_INJECTION\]\s*->\s*\([^)]*:SQLInjection[^)]*\)\s*<-\s*\[:IS_SQL_INJECTION\]\s*-\s*\(m:Mitigation\)",
                    "MATCH (v:Vulnerability)-[:HAS_WEAKNESS]->(w:Weakness) WHERE toLower(w.name) CONTAINS 'sql injection' OR toLower(w.description) CONTAINS 'sql injection' MATCH (m:Mitigation)-[:MITIGATES]->(w)",
                    fixed_query,
                    flags=re.IGNORECASE,
                )
            # Pattern 1: MATCH (v:Vulnerability)-[:IS_SQL_INJECTION]->(s:SQLInjection)
            fixed_query = re.sub(
                r"MATCH\s+\(v:Vulnerability\)\s*-\s*\[:IS_SQL_INJECTION\]\s*->\s*\([^)]*:SQLInjection[^)]*\)\s*",
                "MATCH (v:Vulnerability) ",
                fixed_query,
                flags=re.IGNORECASE,
            )
            # Pattern 3: Any relationship to/from SQLInjection - remove the broken chain completely
            fixed_query = re.sub(
                r"-\s*\[:IS_SQL_INJECTION\]\s*->\s*\([^)]*:SQLInjection[^)]*\)",
                "",
                fixed_query,
                flags=re.IGNORECASE,
            )
            fixed_query = re.sub(
                r"<-\s*\[:IS_SQL_INJECTION\]\s*-\s*\([^)]*:SQLInjection[^)]*\)",
                "",
                fixed_query,
                flags=re.IGNORECASE,
            )
            fixed_query = re.sub(
                r"\([^)]*:SQLInjection[^)]*\)\s*<-\s*\[:IS_SQL_INJECTION\]",
                "",
                fixed_query,
                flags=re.IGNORECASE,
            )
            # Remove any remaining :IS_SQL_INJECTION relationships (broken chains)
            fixed_query = re.sub(
                r"-\s*\[:IS_SQL_INJECTION\]\s*->",
                "",
                fixed_query,
                flags=re.IGNORECASE,
            )
            fixed_query = re.sub(
                r"<-\s*\[:IS_SQL_INJECTION\]\s*-",
                "",
                fixed_query,
                flags=re.IGNORECASE,
            )
            # Also handle :SQLInjection (case variations)
            fixed_query = re.sub(
                r"-\s*\[:SQLInjection\]\s*->",
                "",
                fixed_query,
                flags=re.IGNORECASE,
            )
            # Remove standalone SQLInjection MATCH (any variable name)
            fixed_query = re.sub(
                r"MATCH\s+\([^)]*:SQLInjection[^)]*\)\s*",
                "",
                fixed_query,
                flags=re.IGNORECASE,
            )
            # Remove s variable references in relationships
            # Pattern: -[:EXPLOITS]->(s) or -[:EXPLOITS]->(s:SQLInjection) or -[:HAS_WEAKNESS]->(s)
            # Also handle reverse: <-[:REL]-(s) or (s)<-[:REL]-
            fixed_query = re.sub(
                r"-\s*\[:\w+\]\s*->\s*\(s[^)]*\)",
                "",
                fixed_query,
                flags=re.IGNORECASE,
            )
            fixed_query = re.sub(
                r"<-\s*\[:\w+\]\s*-\s*\(s[^)]*\)",
                "",
                fixed_query,
                flags=re.IGNORECASE,
            )
            fixed_query = re.sub(
                r"\(s[^)]*\)\s*<-\s*\[:\w+\]",
                "",
                fixed_query,
                flags=re.IGNORECASE,
            )
            # Remove standalone (s) references in relationship chains
            fixed_query = re.sub(
                r"->\s*\(s\)",
                "",
                fixed_query,
                flags=re.IGNORECASE,
            )
            fixed_query = re.sub(
                r"\(s\)\s*<-",
                "",
                fixed_query,
                flags=re.IGNORECASE,
            )
            # Remove s variable from RETURN if present (e.g., s.uid AS sql_injection_uid)
            fixed_query = re.sub(
                r",?\s*s\.\w+\s+AS\s+\w+\s*",
                "",
                fixed_query,
                flags=re.IGNORECASE,
            )
            # Fix double MATCH statements (if we have MATCH (v:Vulnerability) MATCH (v)...)
            # This can happen when we remove :IS_SQL_INJECTION, leaving separate MATCH statements
            fixed_query = re.sub(
                r"MATCH\s+\(v:Vulnerability\)\s+MATCH\s+\(v\)",
                "MATCH (v:Vulnerability)",
                fixed_query,
                flags=re.IGNORECASE,
            )
            # Additional cleanup: Handle SQLInjection in variable names or aliases
            # Remove any references to sql_injection variables in WHERE clauses
            fixed_query = re.sub(
                r"\bWHERE\s+.*?\bsql_injection\w*.*?(?=\s+MATCH|\s+RETURN|\s+LIMIT|$)",
                "",
                fixed_query,
                flags=re.IGNORECASE,
            )
            # Remove any AND/OR conditions involving sql_injection variables
            fixed_query = re.sub(
                r"\s+(AND|OR)\s+.*?\bsql_injection\w*.*?(?=\s+MATCH|\s+RETURN|\s+LIMIT|$)",
                "",
                fixed_query,
                flags=re.IGNORECASE,
            )

            # Ensure we have a proper query structure after cleanup
            # If we removed relationships, we might need to rebuild the query properly
            # Check if we still have a valid MATCH for Vulnerabilities
            if (
                "MATCH" in fixed_query.upper()
                and ":Vulnerability" in fixed_query.upper()
            ):
                # If we have Vulnerabilities but no path to Mitigations, rebuild it
                if (
                    ":Mitigation" in fixed_query.upper()
                    and "-[:HAS_WEAKNESS]->" not in fixed_query.upper()
                ):
                    # Try to inject the correct path if it's missing
                    # Find where Vulnerability is matched
                    vuln_match = re.search(
                        r"MATCH\s+\(v:Vulnerability\)", fixed_query, re.IGNORECASE
                    )
                    if vuln_match and "-[:HAS_WEAKNESS]->" not in fixed_query:
                        # Inject the correct path after Vulnerability match
                        before_match = fixed_query[: vuln_match.end()]
                        after_match = fixed_query[vuln_match.end() :]
                        # Insert the correct path
                        fixed_query = (
                            before_match
                            + "-[:HAS_WEAKNESS]->(w:Weakness) WHERE toLower(w.name) CONTAINS 'sql injection' OR toLower(w.description) CONTAINS 'sql injection' "
                            + after_match
                        )

            # Clean up any double spaces, triple spaces, or trailing commas
            fixed_query = re.sub(
                r"\s{2,}", " ", fixed_query
            )  # Multiple spaces -> single space
            fixed_query = re.sub(
                r",\s+,", ",", fixed_query
            )  # Double commas -> single comma
            fixed_query = re.sub(
                r",\s+RETURN", " RETURN", fixed_query, flags=re.IGNORECASE
            )  # Comma before RETURN -> space before RETURN
            # Clean up any MATCH MATCH (should be just one MATCH)
            fixed_query = re.sub(
                r"MATCH\s+MATCH", "MATCH", fixed_query, flags=re.IGNORECASE
            )

        return fixed_query

    def _fix_workrole_match_clauses(self, cypher_query: str, question: str) -> str:
        """
        Fix WorkRole MATCH clauses that incorrectly use 'title' property instead of 'work_role'.

        This fixes queries like:
        - MATCH (wr:WorkRole {title: 'System Administrator'})
        to:
        - MATCH (wr:WorkRole {work_role: 'System Administrator'})

        Also fixes WHERE clauses:
        - WHERE wr.title = 'System Administrator'
        to:
        - WHERE wr.work_role = 'System Administrator'

        Args:
            cypher_query: Cypher query that may have incorrect WorkRole property usage
            question: Original question (for context)

        Returns:
            Fixed query with correct property names
        """
        import re

        # Check if query references WorkRole nodes
        if ":WorkRole" not in cypher_query and "WorkRole" not in cypher_query:
            return cypher_query

        fixed_query = cypher_query

        # Pattern 1: Fix MATCH clauses with {title: '...'}
        # Match: (wr:WorkRole {title: 'System Administrator'})
        # Match including the closing brace to avoid extra braces
        pattern1 = re.compile(r'\{title\s*:\s*([\'"])([^\'"]+)\1\s*\}', re.IGNORECASE)

        def replace_title_in_match(match):
            quote = match.group(1)
            value = match.group(2)
            # Replace {title: 'value'} with {work_role: 'value'}
            # Pattern matches including the opening {, so we replace with {work_role: ...}
            # Use string concatenation to avoid brace escaping issues
            return "{work_role: " + quote + value + quote + "}"

        fixed_query = pattern1.sub(replace_title_in_match, fixed_query)

        # Pattern 2: Fix WHERE clauses with wr.title = '...'
        # Match: WHERE wr.title = 'System Administrator'
        pattern2 = re.compile(
            r'(\bWHERE\s+)(\w+)\.title\s*=\s*([\'"])([^\'"]+)\3', re.IGNORECASE
        )

        def replace_title_in_where(match):
            where_clause = match.group(1)
            var = match.group(2)
            quote = match.group(3)
            value = match.group(4)
            # Verify this is actually a WorkRole variable (heuristic: check if it's followed by WorkRole)
            # We'll do a simple check - if the variable appears before :WorkRole, assume it's WorkRole
            var_before = fixed_query[: match.start()]
            if f"{var}:WorkRole" in var_before or f"({var}:WorkRole" in var_before:
                return f"{where_clause}{var}.work_role = {quote}{value}{quote}"
            return match.group(0)  # Don't change if unsure

        fixed_query = pattern2.sub(replace_title_in_where, fixed_query)

        # Pattern 3: Fix WHERE clauses with wr.title CONTAINS '...'
        pattern3 = re.compile(
            r'(\bWHERE\s+)(\w+)\.title\s+CONTAINS\s+([\'"])([^\'"]+)\3', re.IGNORECASE
        )

        def replace_title_contains(match):
            where_clause = match.group(1)
            var = match.group(2)
            quote = match.group(3)
            value = match.group(4)
            var_before = fixed_query[: match.start()]
            if f"{var}:WorkRole" in var_before or f"({var}:WorkRole" in var_before:
                return f"{where_clause}{var}.work_role CONTAINS {quote}{value}{quote}"
            return match.group(0)

        fixed_query = pattern3.sub(replace_title_contains, fixed_query)

        # Log the fix if it changed
        if fixed_query != cypher_query and self.debug:
            self.debug_formatter.decision(
                "WorkRole Property Fix",
                "Fixed WorkRole query: changed 'title' property to 'work_role' property",
            )
            # Extract the changed part for display
            import difflib

            diff = list(
                difflib.unified_diff(
                    cypher_query.splitlines(keepends=True),
                    fixed_query.splitlines(keepends=True),
                    lineterm="",
                    n=2,
                )
            )[
                3:7
            ]  # Get first few diff lines
            if diff:
                self.debug_formatter.info(f"Property fix applied: {''.join(diff[:2])}")

        return fixed_query

    def _fix_workrole_return_clauses(self, cypher_query: str, question: str) -> str:
        """
        Pre-execution fix: Use schema discovery to fix WorkRole queries with coalesce.

        WorkRole nodes come from multiple sources with different field names:
        - NICE: uses 'title' and 'text'
        - DCWF: uses 'work_role' and 'definition'

        Uses schema discovery to detect available properties and applies coalesce
        to handle both variants. This is schema-aware and generic.

        TODO: This should eventually be moved into _fix_properties_from_schema
        in langchain_cypher_generator.py to handle all node types with field variants.

        Args:
            cypher_query: Cypher query that may need WorkRole field normalization
            question: Original question

        Returns:
            Fixed query with coalesce for WorkRole fields (if both variants exist)
        """
        import re

        # Check if query references WorkRole nodes
        if ":WorkRole" not in cypher_query and "WorkRole" not in cypher_query:
            return cypher_query

        # Look for WorkRole variable
        workrole_var_match = re.search(
            r"\((\w+):WorkRole\)", cypher_query, re.IGNORECASE
        )
        if not workrole_var_match:
            return cypher_query

        var = workrole_var_match.group(1)

        # Use schema discovery to check available properties
        try:
            schema_prompt = self.cypher_generator._get_graph_schema()

            # Pattern: Look for WorkRole schema section and check Available Properties
            workrole_props_pattern = r"WorkRole[^\n]*\n[^\n]*\n[^\n]*\n[^\n]*Available Properties:\s*([^\n]+)"
            match = re.search(
                workrole_props_pattern, schema_prompt, re.IGNORECASE | re.MULTILINE
            )

            if match:
                available_props = [p.strip() for p in match.group(1).split(",")]
                has_title = "title" in available_props
                has_work_role = "work_role" in available_props
                has_text = "text" in available_props
                has_definition = "definition" in available_props

                # Use coalesce if both variants exist
                needs_coalesce_title = has_title and has_work_role
                needs_coalesce_text = has_text and has_definition
            else:
                # If schema lookup fails, assume we need coalesce for robustness
                needs_coalesce_title = True
                needs_coalesce_text = True
        except Exception:
            # If schema lookup fails, use coalesce as safe default
            needs_coalesce_title = True
            needs_coalesce_text = True

        # Only apply fix if coalesce is needed and query uses simple field references
        if not (needs_coalesce_title or needs_coalesce_text):
            return cypher_query

        fixed_query = cypher_query

        # Pattern 1: RETURN var.uid, var.title, var.text (no aliases, no coalesce)
        if needs_coalesce_title and needs_coalesce_text:
            # Both need coalesce
            pattern = rf"RETURN\s+{re.escape(var)}\.uid\s*,\s*{re.escape(var)}\.title\s*,\s*{re.escape(var)}\.text\b"
            replacement = f"RETURN {var}.uid AS uid, coalesce({var}.title, {var}.work_role) AS title, coalesce({var}.text, {var}.definition) AS text"
        elif needs_coalesce_title:
            # Only title needs coalesce
            pattern = rf"RETURN\s+{re.escape(var)}\.uid\s*,\s*{re.escape(var)}\.title\s*,\s*{re.escape(var)}\.text\b"
            replacement = f"RETURN {var}.uid AS uid, coalesce({var}.title, {var}.work_role) AS title, {var}.text AS text"
        else:
            # Only text needs coalesce
            pattern = rf"RETURN\s+{re.escape(var)}\.uid\s*,\s*{re.escape(var)}\.title\s*,\s*{re.escape(var)}\.text\b"
            replacement = f"RETURN {var}.uid AS uid, {var}.title AS title, coalesce({var}.text, {var}.definition) AS text"

        fixed_query = re.sub(pattern, replacement, fixed_query, flags=re.IGNORECASE)

        # Pattern 2: With LIMIT
        pattern2 = rf"RETURN\s+{re.escape(var)}\.uid\s*,\s*{re.escape(var)}\.title\s*,\s*{re.escape(var)}\.text\s+LIMIT"
        if needs_coalesce_title and needs_coalesce_text:
            replacement2 = f"RETURN {var}.uid AS uid, coalesce({var}.title, {var}.work_role) AS title, coalesce({var}.text, {var}.definition) AS text LIMIT"
        elif needs_coalesce_title:
            replacement2 = f"RETURN {var}.uid AS uid, coalesce({var}.title, {var}.work_role) AS title, {var}.text AS text LIMIT"
        else:
            replacement2 = f"RETURN {var}.uid AS uid, {var}.title AS title, coalesce({var}.text, {var}.definition) AS text LIMIT"

        fixed_query = re.sub(pattern2, replacement2, fixed_query, flags=re.IGNORECASE)

        if fixed_query != cypher_query and self.debug:
            print(
                "\n🔧 [DEBUG] WorkRole RETURN clause fix applied (schema-aware coalesce):"
            )
            print(f"   Before: {cypher_query[:200]}...")
            print(f"   After:  {fixed_query[:200]}...")

        return fixed_query

    def _simplify_count_query_with_union(self, cypher_query: str, question: str) -> str:
        """
        Simplify UNION queries for counting questions.

        If a counting question has UNION with a COUNT branch, extract just that branch.
        This fixes cases where the LLM incorrectly adds UNION branches with mismatched columns.

        Args:
            cypher_query: Cypher query with potential UNION
            question: Original question

        Returns:
            Simplified query (just the COUNT branch if found)
        """
        import re

        query_lower = cypher_query.lower()

        # Only simplify if it's a counting question and has UNION with COUNT
        is_counting = any(
            kw in question.lower()
            for kw in ["how many", "count", "number of", "total number"]
        )

        if (
            not is_counting
            or "union" not in query_lower
            or "return count(" not in query_lower
        ):
            return cypher_query  # Don't modify

        # Split by UNION
        branches = re.split(r"\s+UNION\s+", cypher_query, flags=re.IGNORECASE)

        # Find the branch with RETURN COUNT
        count_branch = None
        for branch in branches:
            if "return count(" in branch.lower():
                count_branch = branch.strip()
                break

        if count_branch:
            # Found COUNT branch - use just that one
            # Remove any trailing LIMIT if it exists (we'll add it back if needed)
            count_branch = re.sub(
                r"\s+LIMIT\s+\$?limit\s*$", "", count_branch, flags=re.IGNORECASE
            )

            # Ensure it has LIMIT (most queries need it)
            if "$limit" in query_lower or "limit" in query_lower:
                # Check if limit parameter exists in original query
                if "$limit" in cypher_query:
                    count_branch += " LIMIT $limit"
                else:
                    # Extract numeric limit
                    limit_match = re.search(
                        r"LIMIT\s+(\d+)", cypher_query, re.IGNORECASE
                    )
                    if limit_match:
                        count_branch += f" LIMIT {limit_match.group(1)}"

            return count_branch

        return cypher_query  # Couldn't simplify, return original

    def _attempt_query(
        self,
        question: str,
        attempt_num: int,
        previous_error: Optional[str],
        previous_query: Optional[str],
        limit: int = 10,
    ) -> LLMResult:
        """Execute a single query attempt."""
        try:
            self.debug_formatter.attempt_header(attempt_num)
            if previous_error:
                self.debug_formatter.data(
                    "Previous Error", previous_error, truncate=200
                )
                self.debug_formatter.info(
                    f"Retrying with error feedback: {previous_error[:100]}"
                )

            # For retry attempts (2+), temporarily disable caching to ensure fresh generation
            # This prevents cached wrong queries from being reused
            cache_enabled = True
            if attempt_num > 1:
                # Save current cache state
                original_cache = self.cypher_generator._cache.copy()
                # Temporarily disable cache by clearing it
                self.cypher_generator._cache.clear()
                cache_enabled = False
                self.debug_formatter.info("Cache disabled for fresh generation")

            try:
                # Generate Cypher query with limit
                # Phase 1 always uses gpt-3.5-turbo
                phase1_model = "gpt-3.5-turbo"
                self.debug_formatter.llm_call(
                    "Generate Cypher Query from Natural Language (Phase 1)",
                    input_data=f"Question: {question}\nLimit: {limit}",
                    cost=None,  # Will be set after call
                    model=phase1_model,
                )
                cypher_result = self.cypher_generator.generate_cypher(
                    question, limit=limit
                )
                cypher_query = cypher_result.query
                parameters = cypher_result.parameters

                # Extract token info from result
                # CypherQueryResult has tokens_used field, but we need to estimate input/output split
                tokens_used = getattr(cypher_result, "tokens_used", None)
                input_tokens = None
                output_tokens = None
                if tokens_used:
                    # Rough estimate: 85% input, 15% output (typical for query generation)
                    input_tokens = int(tokens_used * 0.85)
                    output_tokens = tokens_used - input_tokens

                # Show LLM output with full cost and token info
                # Format query output - show full query (not truncated) since it will be shown in query_execution anyway
                query_display = cypher_query  # Full query - will be shown properly in query_execution
                reasoning = getattr(cypher_result, "reasoning", None)
                reasoning_display = (
                    (
                        reasoning[:300] + "..."
                        if reasoning and len(reasoning) > 300
                        else reasoning
                    )
                    if reasoning
                    else None
                )

                output_summary = {
                    "query": query_display,  # Full query shown here
                    "parameters": parameters,
                }
                if reasoning_display:
                    output_summary["reasoning"] = reasoning_display

                phase1_model = "gpt-3.5-turbo"  # Phase 1 always uses gpt-3.5-turbo
                self.debug_formatter.llm_call(
                    "Cypher Query Generated (Phase 1)",
                    output_data=output_summary,
                    cost=getattr(cypher_result, "cost", None),
                    input_tokens=input_tokens,
                    output_tokens=output_tokens,
                    model=phase1_model,
                )
            finally:
                # Restore cache if we disabled it
                if not cache_enabled:
                    self.cypher_generator._cache = original_cache

            # Pre-execution syntax fix: Fix common COUNT syntax errors before execution
            # This helps catch issues before they hit the database
            self.debug_formatter.info("Applying pre-execution syntax fixes...")
            query_before_fixes = cypher_query

            cypher_query_fixed = self._fix_count_syntax_errors(cypher_query, question)
            if cypher_query_fixed != cypher_query:
                self.debug_formatter.decision(
                    "COUNT Syntax Fix", "Fixed COUNT query syntax errors"
                )

            # Also fix WITH clause variable scope errors
            query_before_with = cypher_query_fixed
            cypher_query_fixed = self._fix_with_clause_scope_errors(cypher_query_fixed)
            if cypher_query_fixed != query_before_with:
                self.debug_formatter.decision(
                    "WITH Clause Fix", "Fixed WITH clause variable scope errors"
                )

            # Fix non-existent relationships for mitigation questions
            query_before_mitigations = cypher_query_fixed
            cypher_query_fixed = self._fix_nonexistent_relationships_for_mitigations(
                cypher_query_fixed, question
            )
            if cypher_query_fixed != query_before_mitigations:
                self.debug_formatter.decision(
                    "Relationship Fix", "Fixed non-existent relationship references"
                )

            # Fix WorkRole queries that return wrong fields (wr.title, wr.text don't exist)
            query_before_return = cypher_query_fixed
            cypher_query_fixed = self._fix_workrole_return_clauses(
                cypher_query_fixed, question
            )
            if cypher_query_fixed != query_before_return:
                self.debug_formatter.decision(
                    "WorkRole RETURN Fix",
                    "Fixed WorkRole RETURN clause field references",
                )

            # Fix WorkRole MATCH clauses that use wrong property (title -> work_role)
            query_before_match = cypher_query_fixed
            try:
                cypher_query_fixed = self._fix_workrole_match_clauses(
                    cypher_query_fixed, question
                )
                if cypher_query_fixed != query_before_match:
                    self.debug_formatter.decision(
                        "WorkRole MATCH Fix",
                        "Fixed WorkRole MATCH clause property references",
                    )
            except Exception as e:
                if self.debug:
                    self.debug_formatter.error(f"WorkRole MATCH fix failed: {e}")
                    self.debug_formatter.data(
                        "Query before fix", cypher_query_fixed[:200]
                    )
                    import traceback

                    traceback.print_exc()
                # Don't fail completely - just skip this fix
                pass

            # Show summary if any fixes were applied
            if cypher_query_fixed != query_before_fixes:
                if (
                    ":WorkRole" in cypher_query_fixed
                    or ":IS_SQL_INJECTION" in cypher_query.upper()
                ):
                    print("\n🔧 [DEBUG] Pre-execution fixes applied:")
                    print(f"   Before: {cypher_query[:200]}...")
                    print(f"   After:  {cypher_query_fixed[:200]}...")
            if cypher_query_fixed != cypher_query:
                self.debug_formatter.decision(
                    "Query Syntax Fix Applied",
                    "Fixed relationship or syntax issues before execution",
                )
                self.debug_formatter.data("Before", cypher_query[:200] + "...")
                self.debug_formatter.data("After", cypher_query_fixed[:200] + "...")

            # Also fix UNION issues for counting questions
            # If it's a counting question and has UNION with mismatched columns, simplify it
            question_lower = question.lower()
            is_counting = any(
                kw in question_lower
                for kw in ["how many", "count", "number of", "total number"]
            )
            if (
                is_counting
                and "union" in cypher_query_fixed.lower()
                and "return count(" in cypher_query_fixed.lower()
            ):
                # For counting questions with UNION, try to extract just the COUNT branch
                # This fixes cases where LLM adds unnecessary UNION branches
                simplified = self._simplify_count_query_with_union(
                    cypher_query_fixed, question
                )
                if simplified != cypher_query_fixed:
                    self.debug_formatter.decision(
                        "UNION Simplification",
                        "Simplified UNION query for counting question",
                    )
                    self.debug_formatter.data(
                        "Original", cypher_query_fixed[:150] + "..."
                    )
                    self.debug_formatter.data("Simplified", simplified[:150] + "...")
                    cypher_query_fixed = simplified

            if cypher_query_fixed != cypher_query:
                self.debug_formatter.decision(
                    "Pre-execution Syntax Fix",
                    "Applied syntax fixes before database execution",
                )
                self.debug_formatter.data("Original", cypher_query[:150] + "...")
                self.debug_formatter.data("Fixed", cypher_query_fixed[:150] + "...")
                cypher_query = cypher_query_fixed

            # Execute query against database
            try:
                raw_data = self.db.execute_cypher(cypher_query, parameters)
            except Exception as e:
                # Log the actual query that failed
                if self.debug:
                    self.debug_formatter.error(f"Database execution failed: {e}")
                    self.debug_formatter.data("Failed Query", cypher_query)
                    import traceback

                    self.debug_formatter.data("Traceback", traceback.format_exc())
                raise  # Re-raise to be caught by outer exception handler

            # Ensure raw_data is a list
            if raw_data is None:
                raw_data = []

            # Show query execution results
            self.debug_formatter.query_execution(
                cypher_query, parameters, results_count=len(raw_data)
            )

            # If zero results, provide diagnostic information
            if len(raw_data) == 0:
                self.debug_formatter.warning(
                    "Zero results returned - query may need adjustment"
                )
                # Try to diagnose: check if the main entity exists
                import re

                # Extract node labels from query
                label_matches = re.findall(r"\([^)]*:(\w+)[^)]*\)", cypher_query)
                if label_matches:
                    primary_label = label_matches[0]
                    # Check if any nodes of this type exist
                    check_query = (
                        f"MATCH (n:{primary_label}) RETURN count(n) AS count LIMIT 1"
                    )
                    try:
                        check_result = self.db.execute_cypher(check_query, {})
                        if check_result and len(check_result) > 0:
                            count = check_result[0].get("count", 0)
                            self.debug_formatter.info(
                                f"Diagnostic: Found {count:,} {primary_label} nodes in database"
                            )
                            if count == 0:
                                self.debug_formatter.warning(
                                    f"No {primary_label} nodes exist in database"
                                )
                    except Exception as e:
                        self.debug_formatter.info(f"Could not run diagnostic: {e}")

            # Phase 1: Prepare JSON output (structured data for Phase 2)
            # Note: pagination_info (including truncation detection) will be built later
            # when preparing Phase 1 JSON in process_question() using _build_pagination_info()
            # No need to compute truncation here since it's rebuilt with the full result context
            # Note: Phase 2 will generate the final answer with citations
            # For now, store placeholder - Phase 2 will be called after validation
            enhanced_answer = f"Found {len(raw_data)} results"  # Placeholder

            return LLMResult(
                question=question,
                cypher_query=cypher_query,
                raw_data=raw_data,
                enhanced_answer=enhanced_answer,
                execution_time=0.0,  # Will be set by caller
                llm_cost_usd=getattr(cypher_result, "cost", None),
                llm_tokens_used=getattr(cypher_result, "tokens_used", None),
                success=True,
            )

        except Exception as e:
            # Include full traceback for debugging
            import traceback

            error_details = f"{str(e)}\n\nTraceback:\n{traceback.format_exc()}"
            if self.debug:
                self.debug_formatter.error(
                    f"Attempt {attempt_num} failed with exception"
                )
                self.debug_formatter.data("Error", str(e))
                self.debug_formatter.data("Traceback", traceback.format_exc())
            return LLMResult(
                question=question,
                cypher_query=previous_query or "",
                raw_data=[],
                enhanced_answer=f"Attempt {attempt_num} error: {str(e)}",
                execution_time=0.0,
                success=False,
                error=error_details,
            )

    def _analyze_query_and_suggest_fix(
        self, question: str, cypher_query: str, validation: ValidationResult
    ) -> str:
        """
        Analyze query and validation result to generate specific, actionable feedback.

        Returns a detailed suggestion string that identifies what's wrong and how to fix it.
        """
        import re

        if not validation.mismatch_reason and validation.confidence >= 0.9:
            return ""  # No issue to fix

        suggestions = []

        # Extract expected entity type from question
        expected_types = validation.expected_types
        actual_types = validation.actual_types

        if expected_types and actual_types:
            # Find the primary expected type (the one being asked for)
            type_priority = {
                "Knowledge": 10,
                "Skill": 9,
                "Task": 8,
                "WorkRole": 7,
                "Ability": 6,
                "AttackPattern": 5,
                "Technique": 4,
                "Vulnerability": 3,
                "Weakness": 2,
            }
            primary_expected = max(
                expected_types, key=lambda t: type_priority.get(t, 0)
            )

            # Find variables in the query that match the expected type
            # Search all MATCH clauses for variables of the expected type
            expected_var = None
            # Use a more flexible pattern that matches any variable of the expected type
            var_pattern = rf"\((\w+):{re.escape(primary_expected)}\)"
            var_matches = re.findall(var_pattern, cypher_query, re.IGNORECASE)
            if var_matches:
                # Prefer variables that appear in relationships (more likely to be the target)
                # Otherwise use the first one found
                expected_var = var_matches[0]
                # If there are multiple, prefer one that's used in a relationship pattern
                for var in var_matches:
                    # Check if this variable is used in a relationship (more likely correct)
                    if re.search(
                        rf"\[.*?\]-.*?\({re.escape(var)}|{re.escape(var)}-.*?\[.*?\]",
                        cypher_query,
                        re.IGNORECASE,
                    ):
                        expected_var = var
                        break

            # Find what's actually being returned
            actual_var = None
            return_match = re.search(
                r"RETURN\s+(.+?)(?:\s+LIMIT|$)", cypher_query, re.IGNORECASE | re.DOTALL
            )
            if return_match:
                return_clause = return_match.group(1)
                var_match = re.search(
                    r"(\w+)\.(?:uid|title|name|text)", return_clause, re.IGNORECASE
                )
                if var_match:
                    actual_var = var_match.group(1)
                    # Find what type this variable is
                    type_match = re.search(
                        rf"\({re.escape(actual_var)}:(\w+)\)",
                        cypher_query,
                        re.IGNORECASE,
                    )
                    if type_match:
                        actual_type = type_match.group(1)
                        if actual_type != primary_expected:
                            suggestions.append(
                                f"\nENTITY TYPE MISMATCH DETECTED:\n"
                                f"- The question asks for: {primary_expected} nodes\n"
                                f"- Your query returns: {actual_type} nodes (variable '{actual_var}')\n"
                            )
                            if expected_var:
                                suggestions.append(
                                    f"CORRECTION:\n"
                                    f"- You have a variable '{expected_var}' of type {primary_expected} in your MATCH clause\n"
                                    f"- Change RETURN {actual_var}.uid to RETURN {expected_var}.uid\n"
                                    f"- Change RETURN {actual_var}.title to RETURN {expected_var}.title (or appropriate property)\n"
                                    f"- Change RETURN {actual_var}.text to RETURN {expected_var}.text (or appropriate property)\n"
                                )
                            else:
                                suggestions.append(
                                    f"CORRECTION:\n"
                                    f"- Find or add a variable of type {primary_expected} in your MATCH clause\n"
                                    f"- Use that variable in your RETURN clause, not '{actual_var}'\n"
                                )

        # Add validation-specific feedback
        if validation.mismatch_reason:
            suggestions.append(f"\nVALIDATION ERROR: {validation.mismatch_reason}")

        return "\n".join(suggestions)

    def _create_relaxed_query(
        self,
        original_question: str,
        error: str,
        previous_query: Optional[str],
        attempt: int,
        validation: Optional[ValidationResult] = None,
    ) -> str:
        """
        Create a relaxed/simplified query prompt based on previous failure.

        Attempt 2: Fix syntax errors, relax constraints with schema-aware suggestions
        Attempt 3: Simplify to basic lookup pattern
        """
        if attempt == 2:
            # Second attempt: Fix and relax - ask LLM to regenerate with error context
            query_context = (
                f"\nPrevious query (that failed):\n{previous_query}"
                if previous_query
                else ""
            )

            # Generate dynamic, schema-aware suggestions if validation is available
            specific_fix = ""
            if validation and previous_query:
                specific_fix = self._analyze_query_and_suggest_fix(
                    original_question, previous_query, validation
                )

            # Detect COUNT-related syntax errors and provide specific fixes
            if not specific_fix and previous_query:
                error_lower = error.lower()
                query_lower = previous_query.lower()

                # Check for COUNT syntax errors (missing RETURN before COUNT)
                if "invalid input 'count'" in error_lower and "count" in query_lower:
                    if (
                        "return" not in query_lower
                        or query_lower.index("count") < query_lower.index("return")
                        if "return" in query_lower
                        else True
                    ):
                        specific_fix = (
                            "\n🔴 CRITICAL SYNTAX ERROR: Missing RETURN before COUNT!\n"
                            "You MUST use: RETURN COUNT(...) AS count\n"
                            "NOT: COUNT(...) AS count (missing RETURN)\n"
                            "Example: MATCH (n:Node) RETURN COUNT(DISTINCT n) AS count"
                        )
                # Check for WITH clause variable scope errors
                elif (
                    "variable" in error_lower
                    and "not defined" in error_lower
                    and " with " in query_lower
                ):
                    import re

                    # Extract the undefined variable name from error message
                    var_match = re.search(
                        r"variable\s+[`']?(\w+)[`']?\s+not defined", error_lower
                    )

                    if var_match:
                        undefined_var = var_match.group(1)
                        specific_fix = (
                            f"\n🔴 CRITICAL SYNTAX ERROR: Variable '{undefined_var}' not defined after WITH clause!\n"
                            f"When you use WITH, you MUST include ALL variables you want to use later in RETURN.\n"
                            f"Problem: You're trying to use '{undefined_var}' in RETURN, but it's not in the WITH clause.\n"
                            f"Solution: Either:\n"
                            f"  1. Include '{undefined_var}' in the WITH clause: WITH ..., {undefined_var}, ...\n"
                            f"  2. Or use a different variable in RETURN that WAS included in WITH\n"
                            f"Example: MATCH (v:Vulnerability)-[:REL]->(w:Weakness) WITH w, COUNT(v) AS count RETURN w.uid, count\n"
                            f"         (both 'w' and 'count' are in WITH, so they can be used in RETURN)"
                        )
                # Check for non-existent relationships (especially :IS_SQL_INJECTION)
                question_lower_check = original_question.lower()
                query_upper_check = previous_query.upper() if previous_query else ""
                if (
                    "IS_SQL_INJECTION" in query_upper_check
                    or "SQLInjection" in error_lower
                    or "does not exist" in error_lower
                    or ":SQLInjection" in query_upper_check
                ) and "mitigation" in question_lower_check:
                    specific_fix = (
                        "\n" + "=" * 80 + "\n"
                        "🔴🔴🔴 CRITICAL ERROR: NON-EXISTENT RELATIONSHIP DETECTED 🔴🔴🔴\n"
                        "=" * 80 + "\n"
                        "\n"
                        "YOU ARE USING A RELATIONSHIP THAT DOES NOT EXIST IN THE DATABASE!\n"
                        "\n"
                        "❌ WRONG: :IS_SQL_INJECTION or :SQLInjection or :SQLINJECTION\n"
                        "❌ WRONG: SQLInjection node type (doesn't exist)\n"
                        "❌ WRONG: (v:Vulnerability)-[:IS_SQL_INJECTION]->(si:SQLInjection)\n"
                        "\n"
                        "✅ CORRECT PATTERN FOR SQL INJECTION MITIGATIONS:\n"
                        "   Vulnerability -[:HAS_WEAKNESS]-> Weakness <-[:MITIGATES]- Mitigation\n"
                        "\n"
                        "STEP-BY-STEP CORRECT QUERY STRUCTURE:\n"
                        "1. MATCH Vulnerabilities connected to Weaknesses: MATCH (v:Vulnerability)-[:HAS_WEAKNESS]->(w:Weakness)\n"
                        "2. FILTER Weaknesses by keywords: WHERE toLower(w.name) CONTAINS 'sql injection' OR toLower(w.description) CONTAINS 'sql injection'\n"
                        "3. MATCH Mitigations for those Weaknesses: MATCH (m:Mitigation)-[:MITIGATES]->(w)\n"
                        "4. RETURN Mitigation nodes: RETURN m.uid AS uid, m.name AS title, m.description AS text\n"
                        "\n"
                        "COMPLETE CORRECT QUERY:\n"
                        "─────────────────────────────────────────────────────────────\n"
                        "MATCH (v:Vulnerability)-[:HAS_WEAKNESS]->(w:Weakness)\n"
                        "WHERE toLower(w.name) CONTAINS 'sql injection' OR toLower(w.description) CONTAINS 'sql injection'\n"
                        "MATCH (m:Mitigation)-[:MITIGATES]->(w)\n"
                        "RETURN m.uid AS uid, m.name AS title, m.description AS text\n"
                        "LIMIT $limit\n"
                        "─────────────────────────────────────────────────────────────\n"
                        "\n"
                        "🚨 ABSOLUTE RULES (DO NOT VIOLATE):\n"
                        "1. NEVER use :IS_SQL_INJECTION, :SQLInjection, or :SQLINJECTION - these DON'T EXIST!\n"
                        "2. NEVER use (si:SQLInjection) node type - it doesn't exist!\n"
                        "3. ALWAYS use :HAS_WEAKNESS to connect Vulnerabilities to Weaknesses\n"
                        "4. ALWAYS filter Weaknesses by keywords in WHERE clause (CONTAINS, not relationships)\n"
                        "5. ALWAYS use :MITIGATES relationship (direction: Mitigation -> Weakness)\n"
                        "6. ALWAYS RETURN m.uid (Mitigation), NEVER v.uid (Vulnerability)\n"
                        "\n"
                        "If the question asks for mitigations, you MUST return Mitigation nodes!\n"
                        "=" * 80 + "\n"
                    )
                # Check for UNION syntax errors (mismatched columns)
                elif "union" in query_lower and (
                    "syntaxerror" in error_lower or "invalid" in error_lower
                ):
                    specific_fix = (
                        "\n🔴 CRITICAL SYNTAX ERROR: UNION branches must have identical column names!\n"
                        "All UNION branches must RETURN the same column names.\n"
                        "Example: UNION MATCH (a:A) RETURN a.uid AS uid, a.name AS title\n"
                        "       UNION MATCH (b:B) RETURN b.uid AS uid, b.name AS title\n"
                        "If one branch uses COUNT, both branches MUST use COUNT with the same column names."
                    )
                # Check for counting questions that don't use COUNT
                elif any(
                    kw in original_question.lower()
                    for kw in ["how many", "count", "number of", "total number"]
                ):
                    if "return count(" not in query_lower:
                        specific_fix = (
                            "\n🔴 COUNTING QUESTION DETECTED: You must use COUNT aggregation!\n"
                            "For 'how many' questions, you MUST use: RETURN COUNT(DISTINCT variable) AS count\n"
                            "DO NOT return individual entities. Use COUNT instead.\n"
                            "Example: MATCH (wr:WorkRole)-[:WORKS_WITH]->(t:Technique) RETURN COUNT(DISTINCT wr) AS count"
                        )

            # Fallback generic note if no specific fix generated
            if not specific_fix and (
                "VALIDATION ERROR" in error or "wrong entity types" in error.lower()
            ):
                specific_fix = (
                    "\n5. CRITICAL: Ensure the RETURN clause returns the correct entity type "
                    "requested in the question. Look at what entity type the question asks for, "
                    "find the matching variable in your MATCH clause, and use THAT variable in RETURN."
                )

            # Return a question string (not a full prompt) - generate_cypher will wrap it
            feedback_note = (
                f"\n\n[RETRY ATTEMPT 2 - Previous query failed]\nError: {error}"
            )
            if specific_fix:
                feedback_note += f"\n{specific_fix}"
            elif query_context:
                feedback_note += f"\nPrevious query: {previous_query[:200]}..."
            feedback_note += (
                "\n\nPlease fix the query to return the correct entity type."
            )

            return f"{original_question}{feedback_note}"

        elif attempt == 3:
            # Third attempt: Dramatically simplify with entity type focus
            # Generate dynamic, schema-aware suggestions if validation is available
            specific_fix = ""
            if validation and previous_query:
                specific_fix = self._analyze_query_and_suggest_fix(
                    original_question, previous_query, validation
                )

            # Special handling for zero-result queries: try broader search
            if "no results" in error.lower() or "zero" in error.lower():
                question_lower = original_question.lower()

                # For mitigation questions - ensure Mitigation nodes are returned
                mitigation_keywords = [
                    "mitigation",
                    "mitigate",
                    "mitigates",
                    "addresses",
                    "address",
                ]
                is_mitigation_question = any(
                    kw in question_lower for kw in mitigation_keywords
                ) and (
                    "vulnerability" in question_lower
                    or "weakness" in question_lower
                    or "cwe" in question_lower
                    or "memory safety" in question_lower
                    or "sql injection" in question_lower
                    or "buffer" in question_lower
                )

                if is_mitigation_question:
                    query_upper = previous_query.upper()
                    returns_mitigation = "RETURN" in query_upper and (
                        "M.UID" in query_upper
                        or "M.NAME" in query_upper
                        or "MITIGATION.UID" in query_upper
                    )
                    returns_vulnerability = "RETURN" in query_upper and (
                        "V.UID" in query_upper or "VULNERABILITY.UID" in query_upper
                    )
                    returns_weakness = "RETURN" in query_upper and (
                        "W.UID" in query_upper or "WEAKNESS.UID" in query_upper
                    )
                    has_wrong_rel = (
                        "IS_SQL_INJECTION" in query_upper
                        or ":SQLINJECTION" in query_upper
                    )

                    if (
                        has_wrong_rel
                        or returns_vulnerability
                        or (returns_weakness and not returns_mitigation)
                    ):
                        specific_fix = (
                            "\n🔴 CRITICAL ERROR: Question asks for MITIGATIONS but query has wrong structure!\n"
                            "You are asking for MITIGATIONS, which are separate nodes with their own properties.\n\n"
                            "CORRECT PATTERN FOR MITIGATION QUESTIONS:\n"
                            "1. Find the relevant Vulnerabilities/Weaknesses (filter by keywords like 'SQL injection' or 'memory safety')\n"
                            "2. Match Mitigations that MITIGATE those Weaknesses\n"
                            "3. RETURN Mitigation nodes (m.uid, m.name, m.description), NOT Vulnerabilities or Weaknesses\n\n"
                            "CORRECT RELATIONSHIP DIRECTION:\n"
                            "- Relationship: (m:Mitigation)-[:MITIGATES]->(w:Weakness)\n"
                            "- Direction: Mitigation points TO Weakness (not the reverse)\n\n"
                            "DO NOT USE:\n"
                            "- Non-existent relationships like :IS_SQL_INJECTION or :SQLInjection\n"
                            "- Wrong direction: (w:Weakness)-[:MITIGATES]->(m:Mitigation) ❌\n\n"
                            "EXAMPLE FOR 'mitigations for SQL injection vulnerabilities':\n"
                            "MATCH (v:Vulnerability)-[:HAS_WEAKNESS]->(w:Weakness)\n"
                            "WHERE toLower(w.name) CONTAINS 'sql injection' OR toLower(w.description) CONTAINS 'sql injection'\n"
                            "MATCH (m:Mitigation)-[:MITIGATES]->(w)\n"
                            "RETURN m.uid AS uid, m.name AS title, m.description AS text\n"
                            "LIMIT $limit\n\n"
                            "EXAMPLE FOR 'mitigations address memory safety problems':\n"
                            "MATCH (w:Weakness)\n"
                            "WHERE toLower(w.name) CONTAINS 'buffer' OR toLower(w.name) CONTAINS 'memory'\n"
                            "   OR toLower(w.description) CONTAINS 'buffer overflow'\n"
                            "   OR toLower(w.description) CONTAINS 'memory safety'\n"
                            "MATCH (m:Mitigation)-[:MITIGATES]->(w)\n"
                            "RETURN m.uid AS uid, m.name AS title, m.description AS text\n"
                            "LIMIT $limit\n\n"
                            "🚨 CRITICAL RULES:\n"
                            "1. Question asks for MITIGATIONS - RETURN m.uid, m.name, m.description\n"
                            "2. Relationship: (m:Mitigation)-[:MITIGATES]->(w:Weakness) ✓\n"
                            "3. DO NOT return v.uid (Vulnerability) or w.uid (Weakness) in the final RETURN\n"
                            "4. Filter Weaknesses by keywords (SQL injection, memory safety, buffer) before matching Mitigations"
                        )

                # For Task + CAPEC questions, try simpler path if complex path failed
                if "task" in question_lower and (
                    "capec" in question_lower or "attack pattern" in question_lower
                ):
                    if (
                        "[:PERFORMS]->(t:Task)" in previous_query
                        or "[:WORKS_WITH]->(ap:AttackPattern)" in previous_query
                    ):
                        specific_fix = (
                            "\n🔍 ZERO RESULTS DETECTED: Try a simpler query structure.\n"
                            "If the complex path (Task <- WorkRole -> CAPEC) returns no results, try:\n"
                            "1. Search Tasks directly that mention the keywords\n"
                            "2. Or find Tasks through WorkRoles that work with ANY CAPEC patterns\n"
                            "3. Example: MATCH (t:Task) WHERE toLower(t.description) CONTAINS 'phishing' RETURN t.uid, t.title\n"
                            "   OR: MATCH (wr:WorkRole)-[:PERFORMS]->(t:Task) WHERE EXISTS { (wr)-[:WORKS_WITH]->(:AttackPattern) } RETURN t.uid, t.title"
                        )

                # For correlation questions (require GROUP BY and aggregation)
                correlation_keywords = [
                    "correlation",
                    "relationship between",
                    "compare",
                    "correlate",
                    "association between",
                    "link between",
                ]
                is_correlation_question = any(
                    kw in question_lower for kw in correlation_keywords
                )

                if is_correlation_question:
                    query_upper = previous_query.upper()
                    has_group_by = "GROUP BY" in query_upper
                    has_aggregation = any(
                        agg in query_upper
                        for agg in ["COUNT", "AVG", "SUM", "MAX", "MIN", "COLLECT"]
                    )
                    uses_union_keyword_search = (
                        "UNION" in query_upper and "CONTAINS" in query_upper
                    )

                    if uses_union_keyword_search:
                        specific_fix = (
                            "\n🔴 CRITICAL ERROR: Correlation questions need GROUP BY aggregation, NOT keyword search!\n"
                            "You are asking for a CORRELATION/RELATIONSHIP between two things.\n"
                            "This requires analytical queries with GROUP BY and aggregation functions.\n\n"
                            "CORRECT PATTERN FOR CORRELATION QUESTIONS:\n"
                            "1. MATCH both entities you want to correlate\n"
                            "2. Use GROUP BY to group by one dimension (e.g., severity level)\n"
                            "3. Use COUNT/aggregation to count the other dimension (e.g., WorkRoles per severity)\n"
                            "4. RETURN the grouped results showing the correlation\n\n"
                            "EXAMPLE FOR 'correlation between vulnerability severity and workforce expertise':\n"
                            "MATCH (v:Vulnerability)\n"
                            "WHERE v.severity IS NOT NULL\n"
                            "WITH v.severity AS severity_level, v\n"
                            "MATCH (v)-[:HAS_WEAKNESS]->(w:Weakness)\n"
                            "MATCH (ap:AttackPattern)-[:EXPLOITS]->(w)\n"
                            "MATCH (ap)-[:RELATES_TO]->(t:Technique)\n"
                            "MATCH (wr:WorkRole)-[:WORKS_WITH]->(t)\n"
                            "RETURN severity_level, count(DISTINCT wr) AS workrole_count, count(DISTINCT v) AS cve_count\n"
                            "ORDER BY severity_level\n"
                            "LIMIT $limit\n\n"
                            "🚨 CRITICAL RULES:\n"
                            "1. DO NOT use UNION with CONTAINS\n"
                            "2. MUST use GROUP BY to group by one dimension\n"
                            "3. MUST use COUNT/aggregation to show correlation\n"
                            "4. RETURN grouped results, not individual entities"
                        )
                    elif not has_group_by:
                        specific_fix = (
                            "\n🔴 CRITICAL: Correlation questions require GROUP BY aggregation!\n"
                            "You are asking for a CORRELATION, which means you need to:\n"
                            "1. Group entities by one dimension (e.g., severity levels)\n"
                            "2. Count/aggregate the other dimension (e.g., WorkRoles per severity)\n"
                            "3. Show the relationship pattern\n\n"
                            "Your query is missing GROUP BY. Add:\n"
                            "- WITH ... AS group_dimension\n"
                            "- RETURN group_dimension, COUNT(...) AS count, ...\n\n"
                            "DO NOT just return individual entities - group and aggregate them!"
                        )
                    elif not has_aggregation:
                        specific_fix = (
                            "\n🔴 CRITICAL: Correlation questions require aggregation functions!\n"
                            "You have GROUP BY but no aggregation functions (COUNT, AVG, etc.).\n"
                            "Correlation questions need to COUNT or aggregate to show relationships.\n\n"
                            "Add aggregation: COUNT(DISTINCT variable) AS count\n"
                            "Example: RETURN severity_level, COUNT(DISTINCT wr) AS workrole_count"
                        )

                # For CVE -> Skills questions (multi-hop graph traversal required) - ATTEMPT 3
                if ("skill" in question_lower or "workforce" in question_lower) and (
                    "cve" in question_lower
                    or "vulnerability" in question_lower
                    or "top" in question_lower
                ):
                    query_upper = previous_query.upper()
                    query_lower = previous_query.lower()
                    # Check if query is using UNION with keyword search instead of graph traversal
                    uses_union_with_contains = (
                        "UNION" in query_upper and "CONTAINS" in query_upper
                    )
                    has_cve_to_cwe = "HAS_WEAKNESS" in query_upper
                    has_cwe_to_capec = "EXPLOITS" in query_upper
                    has_capec_to_attack = "RELATES_TO" in query_upper
                    has_attack_to_wr = "WORKS_WITH" in query_upper
                    has_wr_to_skill = "REQUIRES_SKILL" in query_upper
                    returns_skill = (
                        "s:skill" in query_lower or "(s:Skill)" in query_upper
                    )

                    if uses_union_with_contains and not has_cve_to_cwe:
                        # Using UNION keyword search pattern instead of graph traversal
                        specific_fix = (
                            "\n🔴 CRITICAL ERROR: You are using UNION keyword search instead of graph traversal!\n"
                            "This question requires multi-hop graph traversal, NOT text search with UNION.\n\n"
                            "CORRECT PATH: CVE -> CWE -> CAPEC -> ATT&CK -> WorkRole -> Skill\n"
                            "You MUST traverse relationships, not search text!\n\n"
                            "CORRECT QUERY STRUCTURE (COPY THIS EXACT PATTERN):\n\n"
                            "MATCH (v:Vulnerability)\n"
                            "WHERE v.year = 2024\n"
                            "WITH v ORDER BY COALESCE(\n"
                            "  CASE WHEN v.cvss_v31 IS NOT NULL THEN v.cvss_v31.baseScore ELSE NULL END,\n"
                            "  CASE WHEN v.cvss_v30 IS NOT NULL THEN v.cvss_v30.baseScore ELSE NULL END,\n"
                            "  CASE WHEN v.cvss_v2 IS NOT NULL THEN v.cvss_v2.baseScore ELSE NULL END,\n"
                            "  0\n"
                            ") DESC\n"
                            "LIMIT 10\n"
                            "MATCH (v)-[:HAS_WEAKNESS]->(w:Weakness)\n"
                            "MATCH (ap:AttackPattern)-[:EXPLOITS]->(w)\n"
                            "MATCH (ap)-[:RELATES_TO]->(t:Technique)\n"
                            "MATCH (wr:WorkRole)-[:WORKS_WITH]->(t)\n"
                            "MATCH (wr)-[:REQUIRES_SKILL]->(s:Skill)\n"
                            "RETURN DISTINCT s.uid AS uid, s.name AS title, s.description AS text\n"
                            "ORDER BY s.name\n"
                            "LIMIT $limit\n\n"
                            "🚨 CRITICAL RULES:\n"
                            "1. DO NOT use UNION - this is ONE linear path, not multiple branches\n"
                            "2. DO NOT use WHERE clauses to join (e.g., w.uid IN v.uid) - use MATCH with relationships\n"
                            "3. DO NOT use CONTAINS or text search - traverse relationships only\n"
                            "4. The path is: CVE -[:HAS_WEAKNESS]-> CWE <-[:EXPLOITS]- CAPEC -[:RELATES_TO]-> ATT&CK <-[:WORKS_WITH]- WorkRole -[:REQUIRES_SKILL]-> Skill\n"
                            "5. RETURN s.uid, s.name, s.description (Skill node), NOT v, w, ap, t, or wr\n"
                            "6. If you get 0 results after following this path, it's a data limitation - return an explanation"
                        )
                    elif has_cve_to_cwe and not has_wr_to_skill:
                        # Query starts correct path but doesn't complete it
                        missing_steps = []
                        if not has_cwe_to_capec:
                            missing_steps.append("CWE -> CAPEC (use -[:EXPLOITS]-)")
                        if not has_capec_to_attack:
                            missing_steps.append(
                                "CAPEC -> ATT&CK (use -[:RELATES_TO]->)"
                            )
                        if not has_attack_to_wr:
                            missing_steps.append(
                                "ATT&CK -> WorkRole (use <-[:WORKS_WITH]-)"
                            )
                        if not has_wr_to_skill:
                            missing_steps.append(
                                "WorkRole -> Skill (use -[:REQUIRES_SKILL]->)"
                            )

                        specific_fix = (
                            f"\n🔴 CRITICAL: Your query path is incomplete!\n"
                            f"You started the path correctly but are missing: {', '.join(missing_steps)}\n\n"
                            f"COMPLETE PATH REQUIRED:\n"
                            f"1. CVE -[:HAS_WEAKNESS]-> CWE ✓\n"
                            f"2. CWE <-[:EXPLOITS]- CAPEC {'✓' if has_cwe_to_capec else '✗'}\n"
                            f"3. CAPEC -[:RELATES_TO]-> ATT&CK {'✓' if has_capec_to_attack else '✗'}\n"
                            f"4. ATT&CK <-[:WORKS_WITH]- WorkRole {'✓' if has_attack_to_wr else '✗'}\n"
                            f"5. WorkRole -[:REQUIRES_SKILL]-> Skill {'✓' if has_wr_to_skill else '✗'}\n\n"
                            f"Final RETURN must use Skill variable (s:Skill), not WorkRole or other nodes!"
                        )
                    elif has_wr_to_skill and not returns_skill:
                        # Path is complete but RETURN is wrong
                        specific_fix = (
                            "\n🔴 CRITICAL: Your query path is correct but RETURN clause is wrong!\n"
                            "You traversed to Skills correctly, but you're returning the wrong nodes.\n"
                            "You MUST return: RETURN DISTINCT s.uid AS uid, s.name AS title, s.description AS text\n"
                            "NOT WorkRole, Technique, or other nodes!"
                        )

            # Add entity type guidance if we know what's expected
            entity_guidance = ""
            if validation and validation.expected_types:
                type_priority = {
                    "Knowledge": 10,
                    "Skill": 9,
                    "Task": 8,
                    "WorkRole": 7,
                    "Ability": 6,
                    "AttackPattern": 5,
                    "Technique": 4,
                    "Vulnerability": 3,
                    "Weakness": 2,
                }
                if validation.expected_types:
                    primary_expected = max(
                        validation.expected_types, key=lambda t: type_priority.get(t, 0)
                    )
                    entity_guidance = (
                        f"\n\nCRITICAL: The question asks for {primary_expected} nodes. "
                        f"Your query MUST return {primary_expected} nodes in the RETURN clause. "
                        f"Find the {primary_expected} variable in your MATCH clause and use it in RETURN."
                    )
                else:
                    entity_guidance = "\n\nCRITICAL: Ensure your query returns appropriate entity types based on the question."

            # Return a question string (not a full prompt) - generate_cypher will wrap it
            feedback_note = f"\n\n[RETRY ATTEMPT 3 - Simplify and fix]\nPrevious attempts failed: {error}"
            if specific_fix:
                feedback_note += f"\n{specific_fix}"
            if entity_guidance:
                feedback_note += f"\n{entity_guidance}"
            feedback_note += (
                "\n\nSimplify the query and ensure it returns the correct entity type."
            )

            return f"{original_question}{feedback_note}"

        return original_question

    def _build_pagination_info(
        self, cypher_query: str, raw_data: List[Dict[str, Any]]
    ) -> Dict[str, Any]:
        """
        Build pagination info from query and results.

        Args:
            cypher_query: The Cypher query that was executed
            raw_data: Results from the query

        Returns:
            Dictionary with pagination metadata
        """
        import re

        # Extract limit from query if present
        limit_match = re.search(r"LIMIT\s+(\d+)", cypher_query, re.IGNORECASE)
        limit_applied = int(limit_match.group(1)) if limit_match else 10

        results_returned = len(raw_data)
        truncated = results_returned == limit_applied

        return {
            "limit_applied": limit_applied,
            "results_returned": results_returned,
            "truncated": truncated,
            "shortage_detected": (
                results_returned < limit_applied if limit_applied > 0 else False
            ),
            "zero_results": results_returned == 0,
        }

    def _validate_result(self, result: LLMResult, question: str) -> ValidationResult:
        """
        Validate that query results match expected entity types.

        Args:
            result: Query result to validate
            question: Original question

        Returns:
            ValidationResult indicating if entity types match
        """
        if not result.cypher_query or not result.raw_data:
            # Can't validate without query or results
            return ValidationResult(
                is_valid=True,  # Don't fail on uncertainty
                expected_types=set(),
                actual_types=set(),
                confidence=0.5,
            )

        return self.query_validator.validate(
            question=question,
            cypher_query=result.cypher_query,
            results=result.raw_data,
        )

    def _prepare_phase1_json_output(
        self,
        question: str,
        raw_data: List[Dict[str, Any]],
        cypher_query: str,
        pagination_info: Optional[Dict[str, Any]] = None,
        validation: Optional[ValidationResult] = None,
    ) -> Dict[str, Any]:
        """
        Phase 1: Prepare JSON output for Phase 2 enhancement LLM.

        Takes query results and metadata and formats them into a structured
        JSON object that Phase 2 will use to generate the human-readable answer.

        Args:
            question: Original question
            raw_data: Raw results from database
            cypher_query: Cypher query that was executed
            pagination_info: Optional pagination metadata
            validation: Optional validation results

        Returns:
            JSON-compatible dictionary structure for Phase 2
        """

        # Format results for JSON output
        # For "example of [concept]" questions, filter to high-severity CVEs
        question_lower = question.lower()
        is_example_question = (
            "example" in question_lower or "examples" in question_lower
        )
        concept_terms = [
            "shellcode",
            "exploit",
            "malware",
            "ransomware",
            "phishing",
            "botnet",
            "rootkit",
        ]
        is_concept_question = any(term in question_lower for term in concept_terms)
        asking_for_concept_example = is_example_question and is_concept_question

        # Check if this is a COUNT query result
        is_count_result = (
            len(raw_data) > 0
            and "count" in raw_data[0]
            and (
                raw_data[0].get("uid") == "N/A"
                or raw_data[0].get("uid") is None
                or not raw_data[0].get("uid")
            )
        )

        results = []
        for r in raw_data:
            # Special handling for COUNT query results
            if is_count_result and "count" in r:
                # COUNT queries return count value, not entities
                result_dict = {"count": r.get("count")}
                # Include any other count-related fields (like cve_count, cwe_count)
                for key, value in r.items():
                    if key not in ["count", "uid", "title", "text"] and (
                        "count" in key.lower() or key.endswith("_count")
                    ):
                        result_dict[key] = value
                results.append(result_dict)
                continue

            # Normalize field names - handle cases where query returns prefixed fields like wr.uid, wr.title, etc.
            # Look for common patterns: var.uid, var.title, var.text, var.name, var.description, var.definition
            uid = r.get("uid")
            if not uid or uid == "N/A":
                # Try to find prefixed uid fields (wr.uid, v.uid, n.uid, etc.)
                for key in r.keys():
                    if key.endswith(".uid") or key == "uid":
                        uid_value = r.get(key)
                        if uid_value and uid_value != "N/A":
                            uid = uid_value
                            break

                # If still not found, try to extract uid from the query itself
                # This handles cases where query filters by specific entity (e.g., {uid: 'CVE-2024-20439'})
                # but doesn't return uid in the RETURN clause
                if (not uid or uid == "N/A") and cypher_query:
                    import re

                    # Pattern 1: {uid: 'CVE-2024-20439'} or {uid: "CVE-2024-20439"}
                    uid_match = re.search(
                        r"\{uid:\s*['\"]?([CVE-]?\w+-\d+(?:-\d+)?)['\"]?\}",
                        cypher_query,
                        re.IGNORECASE,
                    )
                    if uid_match:
                        uid = uid_match.group(1)
                    else:
                        # Pattern 2: WHERE v.uid = 'CVE-2024-20439' or WHERE v.uid = "CVE-2024-20439"
                        uid_match = re.search(
                            r"WHERE\s+\w+\.uid\s*=\s*['\"]?([CVE-]?\w+-\d+(?:-\d+)?)['\"]?",
                            cypher_query,
                            re.IGNORECASE,
                        )
                        if uid_match:
                            uid = uid_match.group(1)
                    # Only use extracted uid if we're processing the first result
                    # (for single-entity queries like "What is CVE-2024-20439?")
                    if uid and uid != "N/A" and len(raw_data) == 1:
                        pass  # Use extracted uid
                    elif uid and uid == "N/A":
                        uid = "N/A"  # Keep as N/A if extraction failed

            # Extract title - check standard fields first, then prefixed fields
            # For WorkRole nodes, the title is in "work_role" field, not "title"
            title = (
                r.get("title")
                or r.get("name")
                or r.get("work_role")  # WorkRole nodes use "work_role" for title
            )
            if not title or title == "N/A":
                # Try to find prefixed title/name/work_role fields (wr.title, wr.name, wr.work_role, etc.)
                # Check prefixed versions
                for key in r.keys():
                    if (
                        key.endswith(
                            ".work_role"
                        )  # Check work_role first (WorkRole nodes)
                        or key.endswith(".title")
                        or key.endswith(".name")
                        or key == "work_role"
                        or key == "title"
                        or key == "name"
                    ):
                        title_value = r.get(key)
                        if (
                            title_value
                            and title_value != "N/A"
                            and title_value is not None
                        ):
                            title = title_value
                            break

            # Extract text/description - check standard fields first, then prefixed fields
            # For WorkRole nodes, the description is in "definition" field, not "text"
            text = (
                r.get("text")
                or r.get("description")
                or r.get(
                    "definition"
                )  # WorkRole nodes use "definition" for description
                or r.get("descriptions")
            )
            if not text:
                # Try to find prefixed text/description/definition fields (wr.text, wr.description, wr.definition, etc.)
                # Check prefixed versions
                for key in r.keys():
                    if (
                        key.endswith(
                            ".definition"
                        )  # Check definition first (WorkRole nodes)
                        or key.endswith(".text")
                        or key.endswith(".description")
                        or key.endswith(".descriptions")
                        or key == "definition"
                        or key == "text"
                        or key == "description"
                        or key == "descriptions"
                    ):
                        text_value = r.get(key)
                        if text_value:
                            text = text_value
                            break

            # Default values if still not found
            uid = uid if uid and uid != "N/A" else "N/A"
            title = title if title and title != "N/A" else "N/A"
            text = text if text else ""

            # Filter concept example questions to only high-severity CVEs
            if asking_for_concept_example and uid and uid.startswith("CVE-"):
                severity = r.get("severity", "").upper() if r.get("severity") else ""
                cvss_score = (
                    r.get("cvss_v31") or r.get("cvss_score") or r.get("cvss_v30") or 0.0
                )

                # Skip low-severity CVEs for concept example questions
                if severity not in ["CRITICAL", "HIGH"] and (
                    not isinstance(cvss_score, (int, float)) or cvss_score < 7.0
                ):
                    continue  # Skip this CVE

            results.append(
                {
                    "uid": uid,
                    "title": title,
                    "text": text,
                    # Include all fields from raw_data (especially severity and cvss scores)
                    **{
                        k: v
                        for k, v in r.items()
                        if k
                        not in [
                            "uid",
                            "title",
                            "text",
                            "name",
                            "description",
                            "definition",
                        ]
                    },
                }
            )

        # Build metadata
        metadata = {}
        if pagination_info:
            metadata["pagination"] = pagination_info
        if validation:
            metadata["validation"] = {
                "is_valid": validation.is_valid,
                "confidence": validation.confidence,
                "expected_types": list(validation.expected_types),
                "actual_types": list(validation.actual_types),
            }
            if validation.mismatch_reason:
                metadata["validation"]["mismatch_reason"] = validation.mismatch_reason

        # Phase 1 JSON output structure
        phase1_output = {
            "question": question,
            "cypher_query": cypher_query,
            "results": results,
            "result_count": len(raw_data),
            "metadata": metadata if metadata else None,
        }

        return phase1_output

    def _enhance_with_llm(
        self,
        question: str,
        raw_data: List[Dict[str, Any]],
        pagination_info: Optional[Dict[str, Any]] = None,
    ) -> str:
        """
        Phase 1: Legacy method - now calls _prepare_phase1_json_output.

        This method is kept for compatibility but Phase 1 should output JSON.
        """
        # This is now a placeholder - Phase 1 should output JSON, not text
        # Phase 2 will handle the actual enhancement
        if not raw_data:
            return "No results found"
        return f"Found {len(raw_data)} results"  # Placeholder - Phase 2 uses JSON

    def _enhance_with_llm_phase2(
        self,
        question: str,
        raw_data: List[Dict[str, Any]],
        cypher_query: str,
        pagination_info: Optional[Dict[str, Any]],
        validation: Optional[ValidationResult],
    ) -> str:
        """
        Phase 2: Legacy method - converts to JSON format and calls _enhance_with_llm_phase2_from_json.

        This is kept for backwards compatibility but new code should use JSON format.
        """
        # Convert to JSON format
        phase1_json = self._prepare_phase1_json_output(
            question=question,
            raw_data=raw_data,
            cypher_query=cypher_query,
            pagination_info=pagination_info,
            validation=validation,
        )

        # Call the JSON-based method
        return self._enhance_with_llm_phase2_from_json(phase1_json)

    def _should_skip_phase2(self, question: str, results: List[Dict[str, Any]]) -> bool:
        """
        Determine if Phase 2 can be skipped for simple queries (cost optimization).

        Simple queries that don't need LLM enhancement:
        - Single entity lookups (1 result with simple structure)
        - Single property queries (what is the X of Y?)
        - Simple count queries

        Args:
            question: Original question
            results: Raw database results

        Returns:
            True if Phase 2 can be skipped, False otherwise
        """
        # COST OPTIMIZATION: Check if skip is enabled
        skip_enabled = os.getenv("PHASE2_SKIP_SIMPLE_QUERIES", "true").lower() == "true"
        if not skip_enabled:
            return False

        import re

        # Single result with simple structure (1-3 fields)
        if len(results) == 1 and len(results[0]) <= 3:
            # Simple lookup - format directly
            if self.debug:
                self.debug_formatter.info(
                    "Skipping Phase 2: Simple single-result query (cost optimization)"
                )
            return True

        # Single property query patterns
        single_property_patterns = [
            r"what (is|are) (the )?(score|severity|cvss|count|name|uid|id|description|title)( of| for)?",
            r"(show|get|tell me) (the )?(score|severity|cvss|count|name|uid)",
            r"how many",
        ]
        question_lower = question.lower()
        if any(
            re.search(pattern, question_lower) for pattern in single_property_patterns
        ):
            if len(results) <= 1:
                if self.debug:
                    self.debug_formatter.info(
                        "Skipping Phase 2: Single property query (cost optimization)"
                    )
                return True

        # Count queries with simple results
        if re.search(r"(how many|count|number of)", question_lower):
            if len(results) == 1 and any(
                k in results[0] for k in ["count", "number", "total"]
            ):
                if self.debug:
                    self.debug_formatter.info(
                        "Skipping Phase 2: Simple count query (cost optimization)"
                    )
                return True

        return False

    def _enhance_with_llm_phase2_from_json(
        self,
        phase1_json: Dict[str, Any],
    ) -> str:
        """
        Phase 2: Generate final enhanced natural language answer from Phase 1 JSON.

        Takes the JSON structure produced by Phase 1 and uses an LLM to generate
        a comprehensive, well-formatted answer with citations.

        For large result sets (>25), uses simpler formatting to avoid timeouts.
        COST OPTIMIZATION: Skips LLM call for simple queries if enabled.

        Args:
            phase1_json: JSON structure from Phase 1 containing:
                - question: Original question
                - cypher_query: Query that was executed
                - results: List of result dictionaries
                - result_count: Number of results
                - metadata: Pagination, validation, etc.

        Returns:
            Final enhanced natural language answer with citations
        """

        # Extract data from Phase 1 JSON
        question = phase1_json.get("question", "")
        results = phase1_json.get("results", [])
        metadata = phase1_json.get("metadata") or {}

        # COST OPTIMIZATION: Check if we should skip Phase 2 for simple queries
        if self._should_skip_phase2(question, results):
            # Format directly without LLM call
            return self._fallback_answer_formatting_from_json(phase1_json)

        # Check if user asked to ignore database - if so, we still want to call LLM
        question_lower = question.lower()
        ignore_database_phrases = [
            "don't use the database",
            "do not use the database",
            "ignore the database",
            "without database",
            "use general knowledge",
            "use your general knowledge",
            "don't use database",
            "skip database",
            # CLAIRE-specific variations
            "don't use claire",
            "do not use claire",
            "ignore claire",
            "skip claire",
            "without claire",
            "don't use claire-kg",
            "skip claire-kg",
            "ignore claire-kg",
        ]
        should_ignore_database = any(
            phrase in question_lower for phrase in ignore_database_phrases
        )

        # Check if we have zero results from database
        result_count = phase1_json.get("result_count", 0)
        metadata_pagination = metadata.get("pagination", {}) if metadata else {}
        zero_results = (
            result_count == 0
            or len(results) == 0
            or metadata_pagination.get("zero_results", False)
        )

        # If zero results and user didn't explicitly ask to ignore database,
        # still call Phase 2 LLM but prompt it to use general knowledge
        # This provides a useful answer even when the database has no information
        should_use_general_knowledge = zero_results and not should_ignore_database

        # Check if this is a definition/comparison question that needs explanation
        question_lower_check = question.lower()
        is_definition_or_comparison = any(
            phrase in question_lower_check
            for phrase in [
                "what is",
                "what are",
                "what does",
                "difference between",
                "different between",
                "compare",
                "comparison",
                "explain",
                "describe",
                "define",
            ]
        )

        # For large result sets (>25), use simpler formatting to avoid LLM timeouts
        # BUT: For definition/comparison questions or zero results, always use LLM so it can explain
        # even if database results aren't relevant
        if (
            len(results) > 25
            and not is_definition_or_comparison
            and not should_use_general_knowledge
        ):
            # Use structured fallback formatting for large sets (only for list queries)
            return self._fallback_answer_formatting_from_json(phase1_json)

        # Initialize LLM client if needed (reuse from cypher generator)
        if (
            not hasattr(self.cypher_generator, "client")
            or self.cypher_generator.client is None
        ):
            self.cypher_generator._initialize_client()

        # Build comprehensive prompt from JSON
        # If we have zero results, modify the prompt to use general knowledge
        if should_use_general_knowledge:
            # Create a modified phase1_json that tells Phase 2 to use general knowledge
            phase1_json_for_general = phase1_json.copy()
            phase1_json_for_general["_use_general_knowledge"] = True
            phase1_json_for_general["_zero_results_reason"] = (
                "The CLAIRE-KG database does not contain any matching records for this question."
            )
            prompt = self._build_phase2_prompt_from_json(phase1_json_for_general)
        else:
            prompt = self._build_phase2_prompt_from_json(phase1_json)

        # COST OPTIMIZATION: Dynamic token limits based on result size
        result_count = len(results)
        if os.getenv("PHASE2_MAX_TOKENS_DYNAMIC", "true").lower() == "true":
            if result_count <= 10:
                max_tokens = 1500  # Small results
            elif result_count <= 25:
                max_tokens = 2500  # Medium results
            else:
                max_tokens = 4000  # Large results (original)
            if self.debug:
                self.debug_formatter.info(
                    f"Dynamic token limit: {max_tokens} (based on {result_count} results)"
                )
        else:
            max_tokens = 4000  # Original fixed limit

        # COST OPTIMIZATION: Model selection (default to GPT-3.5-turbo, can use GPT-4o-mini)
        phase2_model = os.getenv("PHASE2_MODEL", "gpt-3.5-turbo")
        if self.debug and phase2_model != "gpt-3.5-turbo":
            self.debug_formatter.info(
                f"Using {phase2_model} for Phase 2 (cost optimization)"
            )

        try:
            # Call OpenAI API with configurable model
            response = self.cypher_generator.client.chat.completions.create(
                model=phase2_model,
                messages=[
                    {
                        "role": "system",
                        "content": """You are an expert cybersecurity knowledge assistant. Your task is to transform raw database query results into clear, natural language answers that combine database-backed information with educational context.

You will receive JSON data from Phase 1 containing:
- The original question
- Database results in structured format
- Query information and metadata

Your job is to:
1. Understand the question and what the user is asking for
2. ALWAYS cite database results with [UID] citations (e.g., "CVE-2024-29244 [CVE-2024-29244]")
3. Format the results into a clear, readable answer
4. Provide educational context when appropriate:
   - For definitional questions ("What is...", "What does... describe?"): Start with a clear definition/explanation, then present database results as examples
   - For data queries ("Show me...", "List..."): Lead with the database results, then add context about what they mean
   - For concept questions: Explain the concept first, then show relevant database examples
5. Include ALL database results provided in the JSON data
6. Handle pagination/truncation notes appropriately
7. Address any validation warnings if entity types don't match
8. Add general cybersecurity knowledge context when it enhances understanding (e.g., how vulnerabilities work, what CWEs mean, prevention strategies)

Format your answer as:
- Clear, natural language paragraphs or lists
- Numbered or bulleted lists for multiple results
- Citations in [UID] format after each database result (MANDATORY)
- Educational context when helpful (definitions, explanations, background)
- Notes about pagination if results were truncated
- Contextual information about what the results represent

CRITICAL REQUIREMENTS:
- **RELEVANCE IS MANDATORY**: Only cite database results that directly answer the question. Do NOT include results just because they mention similar keywords.
- **For definitional questions about concepts** (e.g., "What is X?", "What does X mean?"):
  - If the database doesn't contain entities specifically about X (the concept itself), provide a clear educational definition and skip irrelevant results
  - Only include database results if they directly explain or define X itself, not just examples that use X
  - Example: For "What is shellcode?", only include results that define/explain shellcode. DO NOT include CVEs that just mention code execution - those are not about shellcode itself.
- **For entity-specific questions** (e.g., "Show me CVEs for X", "List all Y"): Include all relevant results about that entity
- **Citation Rule**: ALWAYS cite database results with [UID] format, BUT only cite results that are relevant
- **Quality Principle**: A short, accurate answer with no citations is better than a misleading answer with irrelevant citations
- Combine database-backed information with educational context only when results are truly relevant
- Be concise but informative, focusing on answering the question clearly""",
                    },
                    {"role": "user", "content": prompt},
                ],
                temperature=0.3,
                max_tokens=max_tokens,  # COST OPTIMIZATION: Dynamic token limit
                timeout=30,  # Add timeout to prevent hanging
            )

            enhanced_answer = response.choices[0].message.content.strip()

            # Calculate and show cost/token info via debug formatter
            if hasattr(response, "usage"):
                input_tokens = response.usage.prompt_tokens
                output_tokens = response.usage.completion_tokens
                # Calculate cost based on model (gpt-3.5-turbo vs gpt-4o-mini)
                if phase2_model == "gpt-4o-mini":
                    # GPT-4o-mini pricing: $0.15/$0.60 per 1M tokens (input/output)
                    cost = (input_tokens / 1_000_000 * 0.15) + (
                        output_tokens / 1_000_000 * 0.60
                    )
                else:
                    # GPT-3.5-turbo pricing: $0.50/$1.50 per 1M tokens (input/output)
                    cost = (input_tokens / 1_000_000 * 0.50) + (
                        output_tokens / 1_000_000 * 1.50
                    )

                # Update the previous LLM call with cost/token info
                self.debug_formatter.llm_call(
                    "Answer Enhanced (Phase 2)",
                    output_data=(
                        enhanced_answer[:300] + "..."
                        if len(enhanced_answer) > 300
                        else enhanced_answer
                    ),
                    cost=cost,
                    input_tokens=input_tokens,
                    output_tokens=output_tokens,
                    model=phase2_model,  # Show which model was used
                )

            return enhanced_answer

        except Exception as e:
            self.debug_formatter.error(f"LLM enhancement failed: {e}")
            # Fallback to simple formatting from JSON
            return self._fallback_answer_formatting_from_json(phase1_json)

    def _build_phase2_enhancement_prompt(
        self,
        question: str,
        raw_data: List[Dict[str, Any]],
        cypher_query: str,
        pagination_info: Optional[Dict[str, Any]],
        validation: Optional[ValidationResult],
    ) -> str:
        """
        Build comprehensive prompt for Phase 2 enhancement LLM.

        Uses structured format with JSON results for better LLM parsing.
        Includes all context: question, results, query, validation, pagination.
        """
        import json

        # Format results as JSON for better LLM parsing
        results_json = json.dumps(
            [
                {
                    "uid": r.get("uid") or "N/A",
                    "title": r.get("title") or r.get("name") or "N/A",
                    "description": (
                        (
                            text_value[:300] + "..."
                            if len(text_value) > 300
                            else text_value
                        )
                        if text_value
                        else ""
                    ),
                }
                for r in raw_data
                for text_value in [
                    r.get("text") or r.get("description") or r.get("definition") or ""
                ]
            ],
            indent=2,
        )

        # Build metadata JSON
        metadata = {}
        if pagination_info:
            metadata["pagination"] = pagination_info
        if validation:
            metadata["validation"] = {
                "is_valid": validation.is_valid,
                "confidence": validation.confidence,
                "expected_types": list(validation.expected_types),
                "actual_types": list(validation.actual_types),
            }
            if validation.mismatch_reason:
                metadata["validation"]["mismatch_reason"] = validation.mismatch_reason

        # Structured prompt with clear sections
        prompt = f"""# Question
{question}

# Database Results (JSON Format)
{results_json}

# Query Information
Cypher Query: {cypher_query[:400]}...

# Metadata
{json.dumps(metadata, indent=2) if metadata else "None"}

# Task
Transform the database results above into a clear, natural language answer that directly addresses the question.

Requirements:
1. Use the JSON results data to create a formatted answer
2. Format as a numbered/bulleted list with UIDs and titles
3. Include brief, relevant descriptions where helpful
4. Provide context about what was found
5. If metadata indicates pagination limits or validation issues, mention them appropriately
6. Be concise but informative
7. Use proper markdown formatting (bold for IDs, lists, line breaks)
8. Focus on answering the question, not just listing results

Generate the enhanced answer:"""

        return prompt

    def _build_phase2_prompt_from_json(
        self,
        phase1_json: Dict[str, Any],
    ) -> str:
        """
        Build comprehensive prompt for Phase 2 enhancement LLM from Phase 1 JSON.

        Uses structured format with JSON results for better LLM parsing.
        Includes all context: question, results, query, validation, pagination.
        """
        import json

        question = phase1_json.get("question", "")
        results = phase1_json.get("results", [])
        cypher_query = phase1_json.get("cypher_query", "")
        metadata = phase1_json.get("metadata") or {}

        # Check if we should use general knowledge (zero results or explicit request)
        use_general_knowledge = phase1_json.get("_use_general_knowledge", False)
        zero_results_reason = phase1_json.get("_zero_results_reason", "")

        # Format results as JSON (include all fields, not just standard ones)
        # This handles both standard format (uid, title, text) and custom formats (CVSS_Score, Description, etc.)
        # Special handling for COUNT queries that return {"count": N} instead of entities
        formatted_results = []

        # Check if this is a COUNT query result
        is_count_query = (
            len(results) > 0
            and "count" in results[0]
            and (results[0].get("uid") == "N/A" or results[0].get("uid") is None)
        )

        for r in results:  # Include all results (no hardcoded limit)
            # Special handling for COUNT query results
            if is_count_query and "count" in r:
                # COUNT queries return count value, not entities
                result_dict = {
                    "count": r.get("count"),
                }
                # Don't include uid/title for COUNT results to avoid [N/A] citations
            else:
                # Standard entity results
                # Start with standard fields
                result_dict = {
                    "uid": r.get("uid") or "N/A",
                    "title": r.get("title") or "N/A",
                }

                # Add description/text field (truncate long ones)
                text = (
                    r.get("text") or r.get("description") or r.get("Description") or ""
                )
                if text:
                    result_dict["description"] = (
                        (text[:300] + "...") if len(text) > 300 else text
                    )
                else:
                    result_dict["description"] = ""

                # Include ALL other fields (like CVSS_Score, Description, etc.)
                # This ensures custom query results are passed to the LLM
                for key, value in r.items():
                    if key not in [
                        "uid",
                        "title",
                        "text",
                        "name",
                        "description",
                        "definition",
                    ]:
                        # Only add if it's not already added (case-insensitive check)
                        if not any(
                            k.lower() == key.lower() for k in result_dict.keys()
                        ):
                            result_dict[key] = value

            formatted_results.append(result_dict)

        results_json = json.dumps(formatted_results, indent=2)

        # Determine if this is a definitional question
        question_lower = question.lower()
        is_definitional = any(
            phrase in question_lower
            for phrase in ["what is", "what does", "describe", "explain", "define"]
        )
        is_list_query = any(
            phrase in question_lower
            for phrase in ["show me", "list", "find all", "get all", "give me all"]
        )

        # Check if user explicitly asked to NOT use the database
        ignore_database_phrases = [
            "don't use the database",
            "do not use the database",
            "ignore the database",
            "without database",
            "use general knowledge",
            "use your general knowledge",
            "don't use database",
            "skip database",
            # CLAIRE-specific variations
            "don't use claire",
            "do not use claire",
            "ignore claire",
            "skip claire",
            "without claire",
            "don't use claire-kg",
            "skip claire-kg",
            "ignore claire-kg",
        ]
        should_ignore_database = any(
            phrase in question_lower for phrase in ignore_database_phrases
        )

        # Check if results are likely irrelevant for definitional questions
        # For concept questions, if results are just CVEs (not definitions/explanations), they're probably irrelevant
        concept_terms = [
            "shellcode",
            "exploit",
            "malware",
            "ransomware",
            "phishing",
            "botnet",
            "rootkit",
        ]
        is_concept_question = any(term in question_lower for term in concept_terms)

        # Check if question asks for "example of X" where X is a concept (not a vulnerability type)
        is_example_question = (
            "example" in question_lower or "examples" in question_lower
        )
        asking_for_concept_example = is_example_question and is_concept_question

        # Check if database returned work roles when question asks for definitions/explanations
        # Work roles are entities, not definitions - if question asks "what is X" and we get work roles, they're not relevant
        has_work_roles = any(
            r.get("uid")
            and (
                r.get("uid").startswith("WRL")
                or "WorkRole" in str(r.get("title", ""))
                or "Specialist" in str(r.get("title", ""))
                or "Analyst" in str(r.get("title", ""))
            )
            for r in results
        )
        results_are_work_roles = (
            is_definitional
            and has_work_roles
            and len(results) > 0
            and all(
                r.get("uid")
                and (
                    r.get("uid").startswith("WRL")
                    or r.get("uid", "").isdigit()
                    or "Specialist" in str(r.get("title", ""))
                    or "Analyst" in str(r.get("title", ""))
                )
                for r in results[:10]  # Check first 10 to see if they're all work roles
            )
        )

        # Filter results for "example of [concept]" questions: only include high-severity CVEs
        if asking_for_concept_example and results:
            # Filter to only high-severity or high-scoring CVEs
            filtered_results = []
            for r in results:
                uid = r.get("uid", "")
                # Only include CVEs with high severity or CVSS scores
                if uid and uid.startswith("CVE-"):
                    severity = (
                        r.get("severity", "").upper() if r.get("severity") else ""
                    )
                    cvss_score = r.get("cvss_v31") or r.get("cvss_score") or 0.0

                    # Include if CRITICAL/HIGH severity OR CVSS >= 7.0
                    if severity in ["CRITICAL", "HIGH"] or (
                        isinstance(cvss_score, (int, float)) and cvss_score >= 7.0
                    ):
                        filtered_results.append(r)
                else:
                    # Include non-CVE results as-is
                    filtered_results.append(r)

            # Update results if we filtered some out
            if len(filtered_results) < len(results):
                results = filtered_results
                # Rebuild results_json with filtered results
                results_json = json.dumps(
                    [
                        {
                            "uid": r.get("uid") or "N/A",
                            "title": r.get("title") or "N/A",
                            "description": (
                                (text[:300] + "...")
                                if text and len(text) > 300
                                else (text or "")
                            ),
                        }
                        for r in results
                        for text in [r.get("text") or ""]
                    ],
                    indent=2,
                )

        # For pure definitional questions (no "example"), CVEs or WorkRoles are irrelevant
        results_likely_irrelevant = (
            is_definitional
            and not is_example_question  # Only irrelevant for pure definitions, not examples
            and is_concept_question
            and results
            and all(
                r.get("uid") and r.get("uid", "").startswith("CVE-") for r in results
            )
        ) or results_are_work_roles  # Work roles are not definitions/explanations

        # Check if this is a COUNT query (for special handling in prompt)
        is_count_query_result = (
            len(results) > 0
            and "count" in str(results_json).lower()
            and formatted_results
            and "count" in formatted_results[0]
        )

        # Determine dataset source from query/question context for COUNT queries
        dataset_source = None
        count_instruction = ""
        if is_count_query_result:
            question_lower = question.lower()
            cypher_lower = cypher_query.lower()

            # Priority 1: Check Cypher query node labels (most authoritative - what's actually being counted)
            # Important: If question explicitly asks for "vulnerabilities" or "CVEs", prioritize CVE even if query has Weakness nodes
            # (Weakness nodes in query are often just for filtering/joining, not what's being counted)

            # Check for Vulnerability nodes (CVE Dataset) - prioritize if question also mentions vulnerabilities
            # Check both singular and plural forms
            has_vulnerability_in_question = (
                "vulnerability" in question_lower
                or "vulnerabilities" in question_lower
                or "cve" in question_lower
                or "cves" in question_lower
            )
            has_vulnerability_in_query = (
                ":Vulnerability" in cypher_query
                or "(v:Vulnerability)" in cypher_query
                or "match (v:vulnerability)" in cypher_lower
            )

            # Check for Weakness nodes (CWE Dataset)
            has_weakness_in_query = (
                ":Weakness" in cypher_query
                or "(w:Weakness)" in cypher_query
                or "match (w:weakness)" in cypher_lower
            )
            has_weakness_in_question = (
                "weakness" in question_lower or "cwe" in question_lower
            )

            # Decision logic: If question asks for vulnerabilities AND query has Vulnerability nodes -> CVE Dataset
            # Otherwise, check what's actually being counted in the RETURN clause
            if has_vulnerability_in_question and has_vulnerability_in_query:
                dataset_source = "CVE Dataset"
            elif (
                has_weakness_in_question
                and has_weakness_in_query
                and not has_vulnerability_in_question
            ):
                dataset_source = "CWE Dataset"
            # If query has both, check what's in the RETURN clause (if count(*), look at primary MATCH)
            elif has_vulnerability_in_query:
                dataset_source = "CVE Dataset"  # If Vulnerability nodes exist, that's what's being counted
            elif has_weakness_in_query:
                dataset_source = "CWE Dataset"
            # Check for AttackPattern nodes (CAPEC Dataset)
            elif (
                ":AttackPattern" in cypher_query
                or "(ap:AttackPattern)" in cypher_query
                or "match (ap:attackpattern)" in cypher_lower
            ):
                dataset_source = "CAPEC Dataset"
            # Check for Technique nodes (ATT&CK Dataset)
            elif (
                ":Technique" in cypher_query
                or "(t:Technique)" in cypher_query
                or "match (t:technique)" in cypher_lower
            ):
                dataset_source = "ATT&CK Dataset"
            # Check for WorkRole nodes (Workforce Dataset)
            elif (
                ":WorkRole" in cypher_query
                or "(wr:WorkRole)" in cypher_query
                or "match (wr:workrole)" in cypher_lower
            ):
                dataset_source = "Workforce Dataset"

            # Priority 2: If no node label match, check question text (what user is asking for)
            # This handles cases where query structure might not be clear
            if not dataset_source:
                # Check for CVE/Vulnerability keywords (both singular and plural)
                if (
                    "vulnerability" in question_lower
                    or "vulnerabilities" in question_lower
                    or "cve" in question_lower
                    or "cves" in question_lower
                    or "cvss" in question_lower
                ):
                    dataset_source = "CVE Dataset"
                # Check for CWE/Weakness keywords
                elif (
                    "weakness" in question_lower
                    or "cwe" in question_lower
                    or "cwes" in question_lower
                ):
                    dataset_source = "CWE Dataset"
                # Check for CAPEC keywords
                elif "attackpattern" in question_lower or "capec" in question_lower:
                    dataset_source = "CAPEC Dataset"
                # Check for ATT&CK keywords
                elif "technique" in question_lower or "tactics" in question_lower:
                    dataset_source = "ATT&CK Dataset"
                # Check for Workforce keywords
                elif (
                    "workrole" in question_lower
                    or "workforce" in question_lower
                    or "nice" in question_lower
                    or "dcwf" in question_lower
                ):
                    dataset_source = "Workforce Dataset"

            # Priority 3: Fallback - check query text for keywords (check both singular and plural)
            if not dataset_source:
                if (
                    "vulnerability" in cypher_lower
                    or "vulnerabilities" in cypher_lower
                    or "cve" in cypher_lower
                ):
                    dataset_source = "CVE Dataset"
                elif "weakness" in cypher_lower or "cwe" in cypher_lower:
                    dataset_source = "CWE Dataset"
                elif "attackpattern" in cypher_lower or "capec" in cypher_lower:
                    dataset_source = "CAPEC Dataset"
                elif "technique" in cypher_lower or "tactics" in cypher_lower:
                    dataset_source = "ATT&CK Dataset"
                elif (
                    "workrole" in cypher_lower
                    or "workforce" in cypher_lower
                    or "nice" in cypher_lower
                    or "dcwf" in cypher_lower
                ):
                    dataset_source = "Workforce Dataset"

            # Build count instruction based on dataset source
            if dataset_source:
                if self.debug:
                    print("\n[DEBUG] Dataset Source Detection for COUNT query:")
                    print(f"   Question: {question[:80]}...")
                    print(f"   Detected Dataset: {dataset_source}")
                    print(f"   Query snippet: {cypher_query[:150]}...")
                # Make instruction more explicit - emphasize that we're counting what the question asks for
                if (
                    "vulnerability" in question_lower
                    or "vulnerabilities" in question_lower
                ):
                    count_instruction = f'**CRITICAL**: The user asked to count VULNERABILITIES. Even if the query references Weakness/CWE nodes for filtering, you are counting VULNERABILITIES. Always cite [{dataset_source}] - DO NOT use [CWE Dataset] or [N/A]. Example: "There are 1,593 vulnerabilities [{dataset_source}]."'
                elif "weakness" in question_lower or "cwe" in question_lower:
                    count_instruction = f'**CRITICAL**: The user asked to count WEAKNESSES/CWEs. Cite [{dataset_source}] - DO NOT use [CVE Dataset] or [N/A]. Example: "There are 120 weaknesses [{dataset_source}]."'
                else:
                    count_instruction = f'**CRITICAL**: State the count number and cite [{dataset_source}] using brackets. Example: "There were 37,880 items [{dataset_source}]." DO NOT use [Count: 37880] or [N/A] - use [{dataset_source}] instead.'
            else:
                if self.debug:
                    print("\n[DEBUG] Dataset Source Detection: No dataset detected!")
                    print(f"   Question: {question[:80]}...")
                    print(f"   Query: {cypher_query[:150]}...")
                count_instruction = "For single counts: State the count with the data source. If the query mentions CVE/vulnerabilities, use [CVE Dataset]. If it mentions CWE/weaknesses, use [CWE Dataset]. DO NOT use [Count: N] or [N/A]."

        # Build task section separately to avoid Python 3.12+ f-string syntax
        if should_ignore_database:
            task_section = """CRITICAL INSTRUCTION: The user explicitly asked you to NOT use the database and to use your general knowledge instead.

**YOU MUST:**
- IGNORE ALL database results shown above (even if any are present)
- Provide a comprehensive answer using ONLY your general knowledge
- DO NOT mention any CVEs, CWEs, CAPEC IDs, or any database entities
- DO NOT cite database sources with [UID] format
- Answer the question directly using your training data and general knowledge

The user wants an answer based on general knowledge, not database queries."""
        elif use_general_knowledge:
            task_section = f"""CRITICAL INSTRUCTION: The CLAIRE-KG database returned ZERO results for this question.

{zero_results_reason}

**YOU MUST:**
- Provide a comprehensive answer using ONLY your general knowledge
- DO NOT mention that there are no database results (don't say "No results found" or "The database doesn't have this")
- DO NOT cite database sources with [UID] format (there are no database results to cite)
- Answer the question directly using your training data and general knowledge
- Provide useful, informative context about the topic

**Example:** If asked "What jobs use wireshark?", provide information about jobs/roles that typically use Wireshark based on your general knowledge, even though the database has no matching records."""
        elif results_likely_irrelevant:
            task_section = "Create a comprehensive, natural language answer that provides a clear, educational definition. The database results shown above are NOT relevant to answering this definitional question - they are CVEs (vulnerability examples), not definitions. DO NOT include them in your answer. Provide a comprehensive educational definition without any database citations."
        else:
            task_section = " that combines the database results above with appropriate educational context"

        # Build requirements section separately
        if should_ignore_database:
            req_section = """0. **CRITICAL USER INSTRUCTION**: The user explicitly asked you to NOT use the database and to use your general knowledge.
   - DO NOT cite or reference ANY database results, CVEs, CWEs, CAPEC IDs, or any database entities
   - DO NOT use [UID] citation format at all
   - DO NOT mention "the database" or "database results" in your answer
   - Provide a comprehensive answer using ONLY your general knowledge
   - If the user asked for actual code/examples (like shellcode), provide them using your general knowledge"""
        elif use_general_knowledge:
            req_section = f"""0. **ZERO RESULTS - USE GENERAL KNOWLEDGE**: {zero_results_reason}
   - DO NOT cite or reference ANY database results (there are none)
   - DO NOT use [UID] citation format at all (no database results to cite)
   - DO NOT mention "the database doesn't have this" or "no results found" - just answer the question
   - Provide a comprehensive answer using ONLY your general knowledge
   - Be helpful and informative - answer the question as if you're a cybersecurity expert
   - If asked about jobs/roles, tools, techniques, etc., provide general information about them"""
        elif is_count_query_result:
            count_req = (
                "0. **COUNT QUERY - CITATION REQUIREMENT**: The database returned a COUNT value(s), not individual entities."
                + "\n   - The result shows count number(s) (e.g., count: 37880, or cve_count: 37880, cwe_count: 1200)"
                + "\n   - DO NOT use [UID] citations or [N/A] - there are no specific entity UIDs to cite"
                + f"\n   - **{count_instruction}**"
                + '\n   - **IMPORTANT**: Look at what the USER\'S QUESTION asks for (vulnerabilities/CVEs vs weaknesses/CWEs), NOT what nodes appear in the query. If the question says "count vulnerabilities", cite [CVE Dataset] even if Weakness nodes appear in the query.'
                + '\n   - For multiple counts: Cite each count with its dataset source (e.g., "There are 37,880 CVEs [CVE Dataset] and 1,200 CWEs [CWE Dataset] in the database")'
                + "\n   - Use dataset-level citations like [CVE Dataset], [CWE Dataset], [CAPEC Dataset], [ATT&CK Dataset] when appropriate"
            )
            req_section = count_req
        else:
            req_section = "1. **RELEVANCE FIRST**: Only cite database results that directly answer the question. Keywords alone don't make results relevant."

        # Build citation rule section
        if is_count_query_result:
            citation_rule_section = (
                "For COUNT queries: DO NOT use [UID], [N/A], or [Count: N] citations. Instead, cite the dataset source. "
                + "For single counts, use dataset citations like [CVE Dataset], [CWE Dataset], [CAPEC Dataset], [ATT&CK Dataset]. "
                + 'Example: "There were 37,880 vulnerabilities published in 2024 [CVE Dataset]." '
                + 'For multiple counts, cite each: "There are 37,880 CVEs [CVE Dataset] and 1,200 CWEs [CWE Dataset]."'
            )
        else:
            citation_rule_section = (
                "Cite with [UID] format, but ONLY cite truly relevant results"
            )

        # Build context rules
        context_rule1 = (
            "   - Start with a clear definition/explanation of the concept"
            if is_definitional
            else ""
        )
        context_rule2 = (
            "   - Then present database results as specific examples from your database"
            if is_definitional
            else ""
        )
        context_rule3 = (
            "   - For list queries: Present database results first, then add context about what they mean"
            if is_list_query
            else ""
        )

        # Build answer structure sections
        if should_ignore_database or use_general_knowledge:
            answer_structure_section = (
                "- Provide a comprehensive answer using ONLY your general knowledge"
            )
        elif is_count_query_result:
            answer_structure_section = '- For COUNT queries: State the count number directly (e.g., "There were 37,880 vulnerabilities published in 2024"). DO NOT use [UID] citations.'
        elif is_definitional:
            answer_structure_section = (
                "- Definition/explanation first (if definitional question)"
                + "\n- Present all database results with [UID] citations"
            )
        else:
            answer_structure_section = (
                "- Present all database results with [UID] citations"
            )

        answer_structure_section2 = (
            "- Add context about what the results mean"
            if not (should_ignore_database or use_general_knowledge)
            else ""
        )

        # Build final instruction
        final_instruction = (
            "Generate the enhanced answer using your general knowledge (no database citations):"
            if (should_ignore_database or use_general_knowledge)
            else "Generate the enhanced answer with citations and educational context:"
        )

        # Structured prompt with clear sections
        prompt = f"""# Question
{question}

# Database Results (JSON Format)
{results_json}

# Query Information
Cypher Query Executed:
{cypher_query}

# Metadata
{json.dumps(metadata, indent=2) if metadata else "{}"}

# Task
{task_section}

CRITICAL REQUIREMENTS:
{req_section}
2. **For definitional/concept questions** ("What is X?", "What does X mean?"):
   - These questions ask about WHAT something IS, not examples of it
   - **CRITICAL**: Only include database results if they directly DEFINE or EXPLAIN X itself. Examples that use X or mention X in passing are NOT relevant.
   - **Example 1**: "What is shellcode?" 
     * ✅ Include: ATT&CK techniques or CAPEC patterns that explain shellcode (e.g., T1620 mentions shellcode and explains it)
     * ✅ Include: CWE definitions if they explain the concept
     * ❌ DO NOT include: CVEs that just mention "code execution" - those are vulnerabilities that might use shellcode, but don't explain what shellcode IS
   - **Example 2**: "What is a buffer overflow?"
     * ✅ Include: CWE definitions that explain buffer overflow (CWE-119, CWE-120, etc.)
     * ❌ DO NOT include: Random CVEs that happen to mention buffer overflow - only include CWEs that define it
3. **For "example" questions** ("What is an example of X?"):
   - **If X is a vulnerability type** (e.g., "example of buffer overflow"): CVEs ARE relevant examples - include all relevant CVEs
   - **If X is a technique/concept** (e.g., "example of shellcode"): 
     * The database doesn't contain actual code examples of the concept itself
     * However, high-severity CVEs (CRITICAL/HIGH severity or CVSS >= 7.0) that use X are provided as examples for additional research
     * Explain that these CVEs are vulnerabilities that were exploited using X, not examples of X itself
     * Cite only the high-severity/well-known CVEs provided in the results
     * Example format: "CVE-XXXX-YYYY [CVE-XXXX-YYYY] is a high-severity vulnerability that was exploited using shellcode..."
3. **For entity-specific questions** ("Show me CVEs", "List all X"): Include all relevant results
4. **Citation Rule**: {citation_rule_section}
5. **Quality Principle**: An accurate definition with no database citations is better than a misleading answer that forces irrelevant connections
6. Add educational context when appropriate:
   {context_rule1}
   {context_rule2}
   {context_rule3}
   - Explain what the results represent and why they matter
   - Add general cybersecurity knowledge context when it enhances understanding
   - Include prevention strategies or best practices when relevant

Answer Structure:
{answer_structure_section}
{answer_structure_section2}
- Include educational background information when helpful
- Format as clear, readable paragraphs and/or numbered lists

{final_instruction}"""

        return prompt

    def _fallback_answer_formatting(
        self,
        question: str,
        raw_data: List[Dict[str, Any]],
        pagination_info: Optional[Dict[str, Any]],
    ) -> str:
        """
        Fallback answer formatting if Phase 2 LLM call fails.

        Creates a simple formatted answer without LLM.
        """
        if not raw_data:
            return "No results found for your question. The database does not contain any matching records."

        result_count = len(raw_data)

        # Build simple formatted answer
        answer_parts = [
            f"Found {result_count} result{'s' if result_count != 1 else ''}:"
        ]

        for i, result in enumerate(raw_data, 1):  # Include all results in fallback
            uid = result.get("uid", "N/A")
            title = result.get("title", result.get("name", "N/A"))
            answer_parts.append(f"{i}. {uid}: {title}")

        # Removed hardcoded limit - show all results

        if pagination_info:
            truncated = pagination_info.get("truncated", False)
            if truncated:
                answer_parts.append("\n(Results limited - more may be available)")

        return "\n".join(answer_parts)

    def _fallback_answer_formatting_from_json(
        self,
        phase1_json: Dict[str, Any],
    ) -> str:
        """
        Simple fallback formatting if LLM enhancement fails.

        Provides basic numbered list format with citations from Phase 1 JSON.
        """
        results = phase1_json.get("results", [])
        question = phase1_json.get("question", "")
        metadata = phase1_json.get("metadata") or {}
        pagination_info = metadata.get("pagination", {})

        # Check if user asked to ignore database
        question_lower = question.lower()
        ignore_database_phrases = [
            "don't use the database",
            "do not use the database",
            "ignore the database",
            "without database",
            "use general knowledge",
            "use your general knowledge",
            "don't use database",
            "skip database",
            # CLAIRE-specific variations
            "don't use claire",
            "do not use claire",
            "ignore claire",
            "skip claire",
            "without claire",
            "don't use claire-kg",
            "skip claire-kg",
            "ignore claire-kg",
        ]
        should_ignore_database = any(
            phrase in question_lower for phrase in ignore_database_phrases
        )

        if not results:
            if should_ignore_database:
                # If user asked to ignore database, we should have called LLM, not fallback
                # This shouldn't happen, but just in case, return a message
                return "Please try again - there was an issue processing your request to use general knowledge."
            return "No results found for your question."

        answer_lines = [f"Found {len(results)} result(s):\n"]

        for i, result in enumerate(results, 1):
            uid = result.get("uid", "N/A")
            title = result.get("title", "N/A")
            answer_lines.append(f"{i}. {title} [{uid}]")

        if pagination_info:
            truncated = pagination_info.get("truncated", False)
            shortage = pagination_info.get("shortage_detected", False)

            if truncated:
                answer_lines.append(
                    f"\nNote: Results limited to {pagination_info.get('limit_applied', 10)} entries. More results may be available."
                )
            elif shortage:
                answer_lines.append(
                    f"\nNote: Only {len(results)} result(s) found, which is less than the requested limit of {pagination_info.get('limit_applied', 10)}."
                )

        return "\n".join(answer_lines)
