#!/bin/bash
set -e

# Load .env if it exists
if [ -f .env ]; then
    export $(grep -v '^#' .env | grep -v '^\s*$' | xargs)
fi

if [ -z "$OPENAI_API_KEY" ]; then
    echo "Error: OPENAI_API_KEY is not set. Copy .env.example to .env and add your key."
    exit 1
fi

# Auto-start the stack if not running
docker compose up -d claire-kg-docker-graphrag 2>/dev/null

# Wait for Neo4j to be healthy
echo "Waiting for Neo4j..."
until [ "$(docker inspect claire-kg-docker-graphrag --format='{{.State.Health.Status}}' 2>/dev/null)" = "healthy" ]; do
    sleep 5
done

docker compose run --rm app ask "$@"
